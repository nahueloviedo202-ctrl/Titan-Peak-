      "default": "#141720"
    },
    {
      "type": "color",
      "id": "background_color_end",
      "label": "Gradient end",
      "default": "#1c3353"
    },
    {
      "type": "range",
      "id": "background_angle",
      "label": "Gradient angle",
      "min": 0,
      "max": 360,
      "step": 5,
      "unit": "deg",
      "default": 0
