{%- doc -%}
  Products carousel: a heading with prev/next arrows, followed by an
  arrow-controlled, multi-column carousel of product cards (image, title,
  price, discount badge and a CTA button/link to the product page).

  Every product is a nested "_product-carousel-card" block referencing a real
  product resource, so merchants can add, remove or reorder products freely.
  All text, colors, sizes, spacing, radius, column counts, autoplay and speed
  are configurable through the section schema.
{%- enddoc -%}

<script
  src="{{ 'products-carousel.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{%- liquid
  assign section_settings = section.settings
  assign card_count = section.blocks.size

  if section_settings.background_color != blank
    render 'contrast-override', background_color: section_settings.background_color, section_id: section.id
  endif
-%}

<div
  class="section-background{% if section_settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
></div>

<div
  class="products-carousel spacing-style{% if section_settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
  style="
    {% render 'spacing-style', settings: section_settings %}
    --prc-max-width: {{ section_settings.container_max_width }}px;
    --prc-padding-x: {{ section_settings.container_padding }}px;
    --prc-padding-x-mobile: {{ section_settings.container_padding_mobile }}px;
    --prc-header-gap: {{ section_settings.header_gap }}px;
    --prc-heading-color: {{ section_settings.heading_color }};
    --prc-heading-size: {{ section_settings.heading_size }}px;
    --prc-columns: {{ section_settings.desktop_columns }};
    --prc-columns-tablet: {{ section_settings.tablet_columns }};
    --prc-mobile-slide-width: {{ section_settings.mobile_slide_width }}%;
    --prc-gap: {{ section_settings.items_gap }}px;
    --prc-gap-mobile: {{ section_settings.items_gap_mobile }}px;
    --prc-transition-speed: {{ section_settings.transition_speed }}ms;
    --prc-arrow-icon-color: {{ section_settings.arrow_icon_color }};
    --prc-arrow-prev-bg: {{ section_settings.arrow_prev_background }};
    --prc-arrow-next-gradient-start: {{ section_settings.arrow_next_gradient_start }};
    --prc-arrow-next-gradient-end: {{ section_settings.arrow_next_gradient_end }};
    --prc-arrow-size: {{ section_settings.arrow_size }}px;
    --prc-arrow-gap: {{ section_settings.arrow_gap }}px;
    {% if section_settings.card_background_color != blank %}
      --prc-card-bg: {{ section_settings.card_background_color }};
    {% endif %}
    --prc-card-radius: {{ section_settings.card_radius }}px;
    --prc-card-padding: {{ section_settings.card_padding }}px;
    --prc-card-content-gap: {{ section_settings.card_content_gap }}px;
    --prc-image-aspect: {{ section_settings.image_aspect_ratio }};
    --prc-image-fit: {{ section_settings.image_fit }};
    --prc-title-color: {{ section_settings.title_color }};
    --prc-title-size: {{ section_settings.title_size }}px;
    --prc-title-case: {{ section_settings.title_case }};
    --prc-compare-color: {{ section_settings.compare_price_color }};
    --prc-compare-size: {{ section_settings.compare_price_size }}px;
    --prc-price-color: {{ section_settings.price_color }};
    --prc-price-size: {{ section_settings.price_size }}px;
    --prc-badge-bg: {{ section_settings.badge_background_color }};
    --prc-badge-color: {{ section_settings.badge_text_color }};
    --prc-badge-size: {{ section_settings.badge_size }}px;
    --prc-badge-radius: {{ section_settings.badge_radius }}px;
    --prc-button-text-color: {{ section_settings.button_text_color }};
    --prc-button-gradient-start: {{ section_settings.button_gradient_start }};
    --prc-button-gradient-end: {{ section_settings.button_gradient_end }};
    --prc-button-radius: {{ section_settings.button_radius }}px;
    --prc-button-font-size: {{ section_settings.button_font_size }}px;
    --prc-button-padding-block: {{ section_settings.button_padding_block }}px;
    --prc-button-padding-inline: {{ section_settings.button_padding_inline }}px;
    {% if section_settings.background_color != blank %}
      --prc-bg: {{ section_settings.background_color }};
    {% endif %}
  "
  data-testid="products-carousel"
>
  <div class="products-carousel__container">
    {%- if card_count > 0 -%}
      <products-carousel-component
        class="products-carousel__component"
        data-autoplay="{{ section_settings.autoplay }}"
        data-autoplay-speed="{{ section_settings.autoplay_speed }}"
      >
        <div class="products-carousel__header">
          {%- if section_settings.heading != blank -%}
            <h2 class="products-carousel__heading">{{ section_settings.heading }}</h2>
          {%- endif -%}

          {%- if section_settings.show_arrows and card_count > 1 -%}
            <div class="products-carousel__nav products-carousel__nav--header">
              <button
                type="button"
                class="products-carousel__nav-btn products-carousel__nav-btn--prev"
                ref="prevButton[]"
                on:click="/prev"
                aria-label="{{ 'accessibility.slideshow_previous' | t }}"
              >
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 20 20"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                  aria-hidden="true"
                  focusable="false"
                >
                  <path
                    d="M8 5L13 10L8 15"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </button>
              <button
                type="button"
                class="products-carousel__nav-btn products-carousel__nav-btn--next"
                ref="nextButton[]"
                on:click="/next"
                aria-label="{{ 'accessibility.slideshow_next' | t }}"
              >
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 20 20"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                  aria-hidden="true"
                  focusable="false"
                >
                  <path
                    d="M8 5L13 10L8 15"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </button>
            </div>
          {%- endif -%}
        </div>

        <div
          class="products-carousel__wrapper"
          ref="wrapper"
        >
          <div
            class="products-carousel__track"
            ref="track"
          >
            {% content_for 'blocks' %}
          </div>
        </div>

        {%- if section_settings.show_arrows and card_count > 1 -%}
          <div class="products-carousel__nav products-carousel__nav--footer">
            <button
              type="button"
              class="products-carousel__nav-btn products-carousel__nav-btn--prev"
              ref="prevButton[]"
              on:click="/prev"
              aria-label="{{ 'accessibility.slideshow_previous' | t }}"
            >
              <svg
                width="20"
                height="20"
                viewBox="0 0 20 20"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
                focusable="false"
              >
                <path
                  d="M8 5L13 10L8 15"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </button>
            <button
              type="button"
              class="products-carousel__nav-btn products-carousel__nav-btn--next"
              ref="nextButton[]"
              on:click="/next"
              aria-label="{{ 'accessibility.slideshow_next' | t }}"
            >
              <svg
                width="20"
                height="20"
                viewBox="0 0 20 20"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
                focusable="false"
              >
                <path
                  d="M8 5L13 10L8 15"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </button>
          </div>
        {%- endif -%}
      </products-carousel-component>
    {%- else -%}
      <div class="products-carousel__header">
        {%- if section_settings.heading != blank -%}
          <h2 class="products-carousel__heading">{{ section_settings.heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .products-carousel {
    width: 100%;
    overflow: hidden;
    background-color: var(--prc-bg, transparent);
    font-family: var(--font-body--family, inherit);
  }

  .products-carousel__container {
    max-width: var(--prc-max-width, 1600px);
    margin: 0 auto;
    padding-inline: var(--prc-padding-x, 32px);
  }

  .products-carousel__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: var(--prc-header-gap, 32px);
  }

  .products-carousel__heading {
    font-family: var(--font-heading--family, inherit);
    font-weight: 700;
    font-size: var(--prc-heading-size, 36px);
    line-height: 1.2;
    color: var(--prc-heading-color, currentColor);
    margin: 0;
  }

  .products-carousel__nav {
    display: flex;
    align-items: center;
    gap: var(--prc-arrow-gap, 12px);
    flex-shrink: 0;
  }

  .products-carousel__nav--footer {
    display: none;
  }

  .products-carousel__nav-btn {
    width: var(--prc-arrow-size, 40px);
    height: var(--prc-arrow-size, 40px);
    border-radius: 50%;
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--prc-arrow-icon-color, #1a1a1a);
    transition: opacity 0.2s ease;
  }

  .products-carousel__nav-btn--prev {
    background: var(--prc-arrow-prev-bg, #f7f4f2);
  }

  .products-carousel__nav-btn--prev:disabled {
    opacity: 0.35;
  }

  .products-carousel__nav-btn--next {
    background: linear-gradient(to right, var(--prc-arrow-next-gradient-start, #ffed68), var(--prc-arrow-next-gradient-end, #e4b948));
  }

  .products-carousel__nav-btn:disabled {
    cursor: not-allowed;
  }

  .products-carousel__nav-btn svg {
    width: 14px;
    height: 14px;
    display: block;
    flex-shrink: 0;
  }

  .products-carousel__nav-btn--prev svg {
    transform: scaleX(-1);
  }

  .products-carousel__component {
    display: block;
    width: 100%;
  }

  .products-carousel__wrapper {
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  .products-carousel__track {
    display: flex;
    gap: var(--prc-gap-mobile, 16px);
    transition: transform var(--prc-transition-speed, 400ms) ease;
    will-change: transform;
  }

  @media screen and (min-width: 750px) {
    .products-carousel__track {
      gap: var(--prc-gap, 20px);
    }
  }

  @media screen and (max-width: 749px) {
    .products-carousel__container {
      padding-inline: var(--prc-padding-x-mobile, 16px);
    }

    .products-carousel__header {
      margin-bottom: max(16px, calc(var(--prc-header-gap, 32px) * 0.63));
    }

    .products-carousel__heading {
      font-size: max(20px, calc(var(--prc-heading-size, 36px) * 0.78));
    }

    .products-carousel__nav--header {
      display: none;
    }

    .products-carousel__nav--footer {
      display: flex;
      justify-content: center;
      width: 100%;
      margin-top: 24px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Products carousel",
  "class": "section-products-carousel",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "_product-carousel-card"
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "t:content.heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "Shop UltimaPeak Bestsellers"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "t:settings.text_color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "t:settings.size",
      "min": 20,
      "max": 64,
      "step": 1,
      "unit": "px",
      "default": 36
    },
    {
      "type": "header",
      "content": "t:content.carousel"
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "label": "t:settings.columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "tablet_columns",
      "label": "Tablet columns",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "mobile_slide_width",
      "label": "Mobile slide width",
      "min": 50,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 85
    },
    {
      "type": "range",
      "id": "items_gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "items_gap_mobile",
      "label": "Gap (mobile)",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "header_gap",
      "label": "Space below heading",
      "min": 8,
      "max": 64,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "transition_speed",
      "label": "Transition speed",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "ms",
      "default": 400
    },
    {
      "type": "header",
      "content": "Autoplay"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "t:settings.autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "t:settings.speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5,
      "visible_if": "{{ section.settings.autoplay }}"
    },
    {
      "type": "header",
      "content": "t:content.navigation"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "t:settings.show",
      "default": true
    },
    {
      "type": "range",
      "id": "arrow_size",
      "label": "t:settings.size",
      "min": 28,
      "max": 56,
      "step": 1,
      "unit": "px",
      "default": 40,
      "visible_if": "{{ section.settings.show_arrows }}"
    },
    {
      "type": "range",
      "id": "arrow_gap",
      "label": "t:settings.gap",
      "min": 4,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 12,
      "visible_if": "{{ section.settings.show_arrows }}"
    },
    {
      "type": "color",
      "id": "arrow_icon_color",
      "label": "Icon color",
      "default": "#1a1a1a",
      "visible_if": "{{ section.settings.show_arrows }}"
    },
    {
      "type": "color",
      "id": "arrow_prev_background",
      "label": "Previous button background",
      "default": "#f7f4f2",
      "visible_if": "{{ section.settings.show_arrows }}"
    },
    {
      "type": "color",
      "id": "arrow_next_gradient_start",
      "label": "Next button gradient start",
      "default": "#ffed68",
      "visible_if": "{{ section.settings.show_arrows }}"
    },
    {
      "type": "color",
      "id": "arrow_next_gradient_end",
      "label": "Next button gradient end",
      "default": "#e4b948",
      "visible_if": "{{ section.settings.show_arrows }}"
    },
    {
      "type": "header",
      "content": "t:content.size"
    },
    {
      "type": "range",
      "id": "container_max_width",
      "label": "Container max width",
      "min": 960,
      "max": 1920,
      "step": 20,
      "unit": "px",
      "default": 1600
    },
    {
      "type": "range",
      "id": "container_padding",
      "label": "Side padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "container_padding_mobile",
      "label": "Side padding (mobile)",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Card appearance"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "t:settings.background_color",
      "placeholder": "t:settings.default"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "t:settings.corner_radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card padding",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "card_content_gap",
      "label": "Content spacing",
      "min": 4,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        {
          "value": "1 / 1",
          "label": "Square (1:1)"
        },
        {
          "value": "4 / 5",
          "label": "Portrait (4:5)"
        },
        {
          "value": "4 / 3",
          "label": "Landscape (4:3)"
        }
      ],
      "default": "1 / 1"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image fit",
      "options": [
        {
          "value": "contain",
          "label": "Contain"
        },
        {
          "value": "cover",
          "label": "Cover"
        }
      ],
      "default": "contain"
    },
    {
      "type": "header",
      "content": "Product title"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "t:settings.text_color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "t:settings.size",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "select",
      "id": "title_case",
      "label": "Letter case",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "capitalize",
          "label": "Capitalize"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "lowercase",
          "label": "Lowercase"
        }
      ],
      "default": "capitalize"
    },
    {
      "type": "header",
      "content": "Pricing"
    },
    {
      "type": "color",
      "id": "compare_price_color",
      "label": "Compare-at price color",
      "default": "#1a1a1ab3"
    },
    {
      "type": "range",
      "id": "compare_price_size",
      "label": "t:settings.size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "price_size",
      "label": "t:settings.size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Discount badge"
    },
    {
      "type": "checkbox",
      "id": "show_discount_badge",
      "label": "t:settings.show",
      "default": true
    },
    {
      "type": "text",
      "id": "discount_label",
      "label": "t:settings.label",
      "default": "Save",
      "visible_if": "{{ section.settings.show_discount_badge }}"
    },
    {
      "type": "color",
      "id": "badge_background_color",
      "label": "t:settings.background_color",
      "default": "#1a1a1a",
      "visible_if": "{{ section.settings.show_discount_badge }}"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "t:settings.text_color",
      "default": "#ffffff",
      "visible_if": "{{ section.settings.show_discount_badge }}"
    },
    {
      "type": "range",
      "id": "badge_size",
      "label": "t:settings.size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 12,
      "visible_if": "{{ section.settings.show_discount_badge }}"
    },
    {
      "type": "range",
      "id": "badge_radius",
      "label": "t:settings.corner_radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 20,
      "visible_if": "{{ section.settings.show_discount_badge }}"
    },
    {
      "type": "header",
      "content": "t:content.buttons"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:settings.label",
      "default": "Add to Cart"
    },
    {
      "type": "checkbox",
      "id": "button_open_new_tab",
      "label": "t:settings.open_new_tab",
      "default": false
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "t:settings.text_color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "button_gradient_start",
      "label": "Gradient start",
      "default": "#e7b944"
    },
    {
      "type": "color",
      "id": "button_gradient_end",
      "label": "Gradient end",
      "default": "#ffed68"
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "t:settings.corner_radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "t:settings.size",
