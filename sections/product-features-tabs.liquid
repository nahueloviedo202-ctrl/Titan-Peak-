      "min": 8,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "tab_font_size_mobile",
      "label": "Tab label size (mobile)",
      "min": 8,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "header",
      "content": "Feature cards"
