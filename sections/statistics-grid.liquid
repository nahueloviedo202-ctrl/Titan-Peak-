{%- doc -%}
  Renders a "Statistics grid" section: a centered header (heading with a
  metallic accent word + subheading) followed by a responsive grid of stat
  cards, each showing either a large standalone value or a circular progress
  ring, with an optional title and description.

  Every stat is a nested "_statistics-grid-item" block, so merchants can add,
  remove or reorder them freely. All text, colors, sizes, spacing, radius,
  column counts (mobile/tablet/desktop) and card style are configurable
  through the section and block schemas.
{%- enddoc -%}

{%- liquid
  assign section_settings = section.settings
  assign item_count = section.blocks.size

  assign has_heading = false
  if section_settings.heading != blank or section_settings.heading_accent != blank
    assign has_heading = true
  endif
-%}

<div class="section-background"></div>

<div
  class="statistics-grid"
  style="
    --sg-bg-start: {{ section_settings.background_color_start }};
    --sg-bg-end: {{ section_settings.background_color_end }};
    --sg-max-width: {{ section_settings.container_max_width }}px;
    --sg-pad-inline-mobile: {{ section_settings.container_padding_mobile }}px;
    --sg-pad-inline-desktop: {{ section_settings.container_padding_desktop }}px;
    --sg-pad-block-start-mobile: {{ section_settings.padding_top_mobile }}px;
    --sg-pad-block-end-mobile: {{ section_settings.padding_bottom_mobile }}px;
    --sg-pad-block-start-desktop: {{ section_settings.padding_top_desktop }}px;
    --sg-pad-block-end-desktop: {{ section_settings.padding_bottom_desktop }}px;
    --sg-heading-color: {{ section_settings.heading_color }};
    --sg-heading-accent-dark: {{ section_settings.heading_accent_dark }};
    --sg-heading-accent-light: {{ section_settings.heading_accent_light }};
    --sg-heading-size-mobile: {{ section_settings.heading_size_mobile }}px;
    --sg-heading-size-desktop: {{ section_settings.heading_size_desktop }}px;
    --sg-subheading-color: {{ section_settings.subheading_color }};
    --sg-subheading-size-mobile: {{ section_settings.subheading_size_mobile }}px;
    --sg-subheading-size-desktop: {{ section_settings.subheading_size_desktop }}px;
    --sg-header-gap: {{ section_settings.header_gap }}px;
    --sg-columns-mobile: {{ section_settings.columns_mobile }};
    --sg-columns-tablet: {{ section_settings.columns_tablet }};
    --sg-columns-desktop: {{ section_settings.columns_desktop }};
    --sg-grid-gap-mobile: {{ section_settings.items_gap_mobile }}px;
    --sg-grid-gap-tablet: {{ section_settings.items_gap_tablet }}px;
    --sg-grid-gap-desktop: {{ section_settings.items_gap_desktop }}px;
    --sg-grid-max-width-tablet: {{ section_settings.grid_max_width_tablet }}px;
    --sg-grid-max-width-mobile: {{ section_settings.grid_max_width_mobile }}px;
    --sg-card-bg: {{ section_settings.card_background_color }};
    --sg-card-radius: {{ section_settings.card_radius }}px;
    --sg-card-shadow: {% if section_settings.card_shadow %}0 2px 10px rgba(0, 0, 0, 0.08){% else %}none{% endif %};
    --sg-card-padding-mobile: {{ section_settings.card_padding_mobile }}px;
    --sg-card-padding-desktop: {{ section_settings.card_padding_desktop }}px;
    --sg-card-min-height-mobile: {{ section_settings.card_min_height_mobile }}px;
    --sg-card-min-height-desktop: {{ section_settings.card_min_height_desktop }}px;
    --sg-value-color: {{ section_settings.value_color }};
    --sg-value-size-mobile: {{ section_settings.value_size_mobile }}px;
    --sg-value-size-desktop: {{ section_settings.value_size_desktop }}px;
    --sg-circle-track-color: {{ section_settings.circle_track_color }};
    --sg-circle-progress-color: {{ section_settings.circle_progress_color }};
    --sg-circle-stroke-width: {{ section_settings.circle_stroke_width }};
    --sg-circle-size-mobile: {{ section_settings.circle_size_mobile }}px;
    --sg-circle-size-desktop: {{ section_settings.circle_size_desktop }}px;
    --sg-circle-value-size-mobile: {{ section_settings.circle_value_size_mobile }}px;
    --sg-circle-value-size-desktop: {{ section_settings.circle_value_size_desktop }}px;
    --sg-title-color: {{ section_settings.title_color }};
    --sg-title-size-mobile: {{ section_settings.title_size_mobile }}px;
    --sg-title-size-desktop: {{ section_settings.title_size_desktop }}px;
    --sg-description-color: {{ section_settings.description_color }};
    --sg-description-size-mobile: {{ section_settings.description_size_mobile }}px;
    --sg-description-size-desktop: {{ section_settings.description_size_desktop }}px;
  "
  data-testid="statistics-grid"
>
  <div class="sg-container">
    {%- if has_heading or section_settings.subheading != blank -%}
      <header class="sg-header">
        {%- if has_heading -%}
          <h2 class="sg-heading">
            {{- section_settings.heading -}}
            {%- if section_settings.heading_accent != blank -%}
              <span class="sg-heading-accent">{{ section_settings.heading_accent }}</span>
            {%- endif -%}
          </h2>
        {%- endif -%}

        {%- if section_settings.subheading != blank -%}
          <p class="sg-subheading">{{ section_settings.subheading }}</p>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- if item_count > 0 -%}
      <div class="sg-grid">
        {% content_for 'blocks' %}
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .statistics-grid {
    width: 100%;
    overflow: hidden;
    text-align: center;
    background: linear-gradient(180deg, var(--sg-bg-start, #1c3353), var(--sg-bg-end, #141720) 97%);
    padding-block: var(--sg-pad-block-start-mobile, 0px) var(--sg-pad-block-end-mobile, 40px);
  }

  .sg-container {
    max-width: var(--sg-max-width, 1200px);
    margin: 0 auto;
    padding-inline: var(--sg-pad-inline-mobile, 20px);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .sg-header {
    margin-bottom: var(--sg-header-gap, 40px);
    width: 100%;
  }

  .sg-heading {
    margin: 0 0 15px;
    color: var(--sg-heading-color, #ffffff);
    font-size: var(--sg-heading-size-mobile, 36px);
    font-weight: var(--font-weight-bold);
    line-height: 1.2;
  }

  .sg-heading-accent {
    display: inline-block;
    margin-left: 5px;
    background: linear-gradient(180deg, var(--sg-heading-accent-dark, #a3a3a3), var(--sg-heading-accent-light, #ffffff) 55%, var(--sg-heading-accent-dark, #a3a3a3));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }

  .sg-subheading {
    max-width: 600px;
    margin: 0 auto;
    color: var(--sg-subheading-color, #ffffff);
    font-size: var(--sg-subheading-size-mobile, 14px);
    line-height: 1.5;
  }

  .sg-grid {
    display: grid;
    grid-template-columns: repeat(var(--sg-columns-mobile, 2), 1fr);
    grid-auto-rows: 1fr;
    gap: var(--sg-grid-gap-mobile, 8px);
    width: 100%;
    max-width: var(--sg-grid-max-width-mobile, 500px);
    margin-inline: auto;
    box-sizing: border-box;
    place-items: center;
    justify-content: center;
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .sg-grid {
      grid-template-columns: repeat(var(--sg-columns-tablet, 2), 1fr);
      gap: var(--sg-grid-gap-tablet, 20px);
      max-width: var(--sg-grid-max-width-tablet, 600px);
    }
  }

  @media screen and (min-width: 750px) {
    .statistics-grid {
      padding-block: var(--sg-pad-block-start-desktop, 0px) var(--sg-pad-block-end-desktop, 60px);
    }

    .sg-container {
      padding-inline: var(--sg-pad-inline-desktop, 40px);
    }

    .sg-heading {
      font-size: var(--sg-heading-size-desktop, 52px);
    }

    .sg-subheading {
      font-size: var(--sg-subheading-size-desktop, 14px);
    }
  }

  @media screen and (min-width: 990px) {
    .sg-grid {
      grid-template-columns: repeat(var(--sg-columns-desktop, 4), 1fr);
      gap: var(--sg-grid-gap-desktop, 20px);
      max-width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
