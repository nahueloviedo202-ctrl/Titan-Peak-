{%- doc -%}
  Renders a footer text column: a bold heading followed by a rich text
  paragraph (used for things like store address / contact details).

  Colors, sizes and spacing are controlled by the parent section via CSS
  custom properties. Meant to be used exclusively as a child block of
  `sections/footer-custom.liquid`.
{%- enddoc -%}

{%- liquid
  assign text_settings = block.settings
-%}

<div
  class="footer-columns__block footer-columns__block--text"
  {{ block.shopify_attributes }}
>
  {%- if text_settings.heading != blank -%}
    <p class="footer-columns__heading">{{ text_settings.heading }}</p>
  {%- endif -%}

  {%- if text_settings.content != blank -%}
    <div class="footer-columns__text rte">{{ text_settings.content }}</div>
  {%- endif -%}
</div>

{% stylesheet %}
  .footer-columns__block--text {
    flex-basis: var(--fc-text-basis, 25%);
    max-width: var(--fc-text-max-width, 320px);
  }

  .footer-columns__text {
    opacity: var(--fc-link-opacity, 0.7);
  }

  .footer-columns__text :is(p, ul, ol) {
    margin: 0;
  }

  .footer-columns__text a {
    color: inherit;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Footer text",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "Get in touch"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>Add your store address or contact details here.</p>"
    }
  ],
  "presets": [
    {
      "name": "Footer text"
    }
  ]
}
{% endschema %}
