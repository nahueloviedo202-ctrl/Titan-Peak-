{%- doc -%}
  Hero CTA button: a gradient-filled call-to-action link with an optional
  trailing arrow icon. Matches the reference design's gold gradient button.

  Meant to be used exclusively as a child block of `sections/hero.liquid`.
{%- enddoc -%}

{%- liquid
  assign cta_settings = block.settings
-%}

{%- if cta_settings.label != blank -%}
  <a
    href="{{ cta_settings.link | default: '#' }}"
    class="hero-cta-button"
    style="
      --hero-cta-gradient-start: {{ cta_settings.gradient_start }};
      --hero-cta-gradient-end: {{ cta_settings.gradient_end }};
      --hero-cta-text-color: {{ cta_settings.text_color }};
      --hero-cta-radius: {{ cta_settings.corner_radius }}px;
      --hero-cta-font-size: {{ cta_settings.font_size }}px;
      --hero-cta-padding-block: {{ cta_settings.padding_block }}px;
      --hero-cta-padding-inline: {{ cta_settings.padding_inline }}px;
    "
    {% if cta_settings.open_in_new_tab %}
      target="_blank"
      rel="noopener"
    {% endif %}
    {{ block.shopify_attributes }}
  >
    {{- cta_settings.label -}}
    {%- if cta_settings.show_icon -%}
      <svg
        class="hero-cta-button__icon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        focusable="false"
      >
        <line
          x1="5"
          y1="12"
          x2="19"
          y2="12"
        />
        <polyline points="12 5 19 12 12 19" />
      </svg>
    {%- endif -%}
  </a>
{%- endif -%}

{% stylesheet %}
  .hero-cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: var(--hero-cta-padding-block, 16px) var(--hero-cta-padding-inline, 64px);
    background: linear-gradient(to bottom, var(--hero-cta-gradient-start, #e7b944), var(--hero-cta-gradient-end, #ffed68));
    border-radius: var(--hero-cta-radius, 12px);
    color: var(--hero-cta-text-color, #1a1a1a);
    font-size: var(--hero-cta-font-size, 18px);
    font-weight: 700;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    line-height: 1.44;
    transition: opacity 0.2s ease;
  }

  .hero-cta-button:hover {
    opacity: 0.9;
    color: var(--hero-cta-text-color, #1a1a1a);
  }

  .hero-cta-button__icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  @media screen and (max-width: 749px) {
    .hero-cta-button {
      width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero CTA button",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "t:settings.label",
      "default": "Shop our best sellers"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:settings.link"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "t:settings.open_new_tab",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "t:settings.show",
      "default": true
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "color",
      "id": "gradient_start",
      "label": "Gradient start",
      "default": "#e7b944"
    },
    {
      "type": "color",
      "id": "gradient_end",
      "label": "Gradient end",
      "default": "#ffed68"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:settings.text_color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "t:settings.corner_radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "t:settings.size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "padding_block",
      "label": "Vertical padding",
      "min": 8,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_inline",
      "label": "Horizontal padding",
      "min": 16,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Hero CTA button"
    }
  ]
}
{% endschema %}
