

{%- doc -%}
  Renders a rich text paragraph for the "Image with accordion" section. Each
  paragraph controls its own color, font size (mobile/desktop) and vertical
  spacing, so several paragraphs can be stacked with different styling (for
  example a larger intro paragraph followed by a smaller disclaimer).

  Meant to be used exclusively as a child block of `sections/image-with-text-accordion.liquid`.
{%- enddoc -%}

{%- liquid
  assign block_settings = block.settings
-%}

{%- if block_settings.text != blank -%}
  <div
    class="itwa-paragraph rte"
    style="
      color: {{ block_settings.text_color }};
      margin-top: {{ block_settings.margin_top }}px;
      margin-bottom: {{ block_settings.margin_bottom }}px;
      --itwa-paragraph-font-size-mobile: {{ block_settings.font_size_mobile }}rem;
      --itwa-paragraph-font-size-desktop: {{ block_settings.font_size_desktop }}rem;
    "
    {{ block.shopify_attributes }}
  >
    {{ block_settings.text }}
  </div>
{%- endif -%}

{% stylesheet %}
  .itwa-paragraph {
    line-height: 1.6;
    font-size: var(--itwa-paragraph-font-size-mobile, 1rem);
  }

  .itwa-paragraph p {
    margin: 0 0 0.5em;
  }

  .itwa-paragraph p:last-child {
    margin-bottom: 0;
  }

  .itwa-paragraph strong {
    font-weight: 600;
  }

  .itwa-paragraph em {
    font-style: italic;
  }

  .itwa-paragraph a {
    color: inherit;
    text-decoration: underline;
  }

  @media screen and (min-width: 750px) {
    .itwa-paragraph {
      font-size: var(--itwa-paragraph-font-size-desktop, 1rem);
      line-height: 1.5;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Paragraph",
  "tag": null,
  "settings": [
    {
      "type": "richtext",
      "id": "text",
      "label": "t:settings.text",
      "default": "<p>Add your text here.</p>"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:settings.text_color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "t:content.size"
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "Font size (mobile)",
      "min": 0.8,
      "max": 3,
      "step": 0.1,
      "unit": "rem",
      "default": 1
    },
    {
      "type": "range",
      "id": "font_size_desktop",
      "label": "Font size (desktop)",
      "min": 0.8,
      "max": 3.5,
      "step": 0.1,
      "unit": "rem",
      "default": 1.1
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Space above",
      "min": -40,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Space below",
      "min": -40,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Paragraph",
      "settings": {
        "text": "<p>Add your text here.</p>"
      }
    }
  ]
}
{% endschema %}
