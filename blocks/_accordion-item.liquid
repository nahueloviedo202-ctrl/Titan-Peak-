{%- doc -%}
  Renders a single collapsible accordion card: a trigger (title + icon)
  and a rich text panel, reusing the theme's native `accordion-custom`
  component for the animated expand/collapse (no extra JavaScript).

  Private block, scoped to the `accordion-group` block only.
{%- enddoc -%}

{% liquid
  assign item_settings = block.settings
%}

{% capture accordion_children %}
  <details
    class="accordion-item__details"
    {% if item_settings.open_by_default %}
      open
    {% endif %}
  >
    <summary class="accordion-item__trigger">
      <h3 class="accordion-item__title">{{ item_settings.title }}</h3>
      <span class="accordion-item__icon icon-caret" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </span>
      <span class="accordion-item__icon icon-plus" aria-hidden="true">
        {{ 'icon-plus.svg' | inline_asset_content }}
      </span>
    </summary>
    <div class="details-content">
      {%- if item_settings.content != blank -%}
        <div class="accordion-item__content">{{ item_settings.content }}</div>
      {%- endif -%}
    </div>
  </details>
{% endcapture %}

<div
  class="accordion-item"
  {{ block.shopify_attributes }}
>
  {% render 'accordion-custom-component',
    children: accordion_children,
    open_by_default_on_desktop: item_settings.open_by_default,
    open_by_default_on_mobile: item_settings.open_by_default
  %}
</div>

{% stylesheet %}
  .accordion-item {
    display: block;
    background-color: var(--ag-card-bg, #fcfaf5);
    border-radius: var(--ag-card-radius, 12px);
    overflow: hidden;
  }

  .accordion-item__trigger {
    width: 100%;
    padding: var(--ag-trigger-padding-block, 20px) var(--ag-trigger-padding-inline, 24px);
    justify-content: space-between;
    gap: var(--ag-trigger-gap, 20px);
    background: none;
    text-align: left;
    transition: background-color var(--ag-transition-speed, 250ms) ease;
  }

  .accordion-item__trigger:hover {
    background-color: var(--ag-trigger-hover-bg, rgba(0, 0, 0, 0.03));
  }

  .accordion-item__trigger:focus-visible {
    outline: 2px solid var(--ag-focus-color, #a45b2c);
    outline-offset: -2px;
  }

  .accordion-item__title {
    margin: 0;
    font-size: var(--ag-title-size, 16px);
    font-weight: var(--ag-title-weight, 500);
    line-height: 1.46;
    color: var(--ag-title-color, #1a1a1a);
  }

  .accordion-item__icon {
    width: var(--ag-icon-size, 24px);
    height: var(--ag-icon-size, 24px);
    flex-shrink: 0;
    color: var(--ag-icon-color, #212529);
    transition: transform var(--ag-transition-speed, 250ms) ease;
  }

  .accordion-item__icon svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .accordion-item__details[open] .icon-caret {
    transform: rotate(180deg);
  }

  .accordion-item__details[open] .icon-plus .horizontal {
    transform: rotate(90deg);
  }

  .accordion-item__details[open] .icon-plus .vertical {
    transform: rotate(90deg);
    opacity: 0;
  }

  .accordion-item__content {
    padding: var(--ag-content-padding, 20px);
    font-size: var(--ag-content-size, 15px);
    line-height: var(--ag-content-line-height, 1.6);
    color: var(--ag-content-color, #212529);
  }

  .accordion-item__content :is(ul, ol) {
    padding-inline-start: 24px;
  }

  .accordion-item__content p {
    margin: 0 0 1em;
  }

  .accordion-item__content p:last-child {
    margin-bottom: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Accordion item",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Accordion item"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>Add the item's content.</p>"
    },
    {
      "type": "checkbox",
      "id": "open_by_default",
      "label": "Open by default",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Accordion item"
    }
  ]
}
{% endschema %}
