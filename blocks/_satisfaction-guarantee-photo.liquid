

{%- doc -%}
  Renders a single "polaroid" photo for the "Satisfaction guarantee" section
  photo cluster (e.g. customer/product photos scattered above the heading).

  Size, gap and appearance are controlled by the parent section via CSS
  custom properties; this block only carries the image and its rotation.

  Meant to be used exclusively as a child block of `sections/satisfaction-guarantee.liquid`.
{%- enddoc -%}

{%- liquid
  assign photo_settings = block.settings
-%}

{%- if photo_settings.image != blank -%}
  <div
    class="sgt-photo"
    style="--sgt-photo-rotate: {{ photo_settings.rotation }}deg;"
    {{ block.shopify_attributes }}
  >
    {{
      photo_settings.image
      | image_url: width: 400
      | image_tag:
        widths: '100, 200, 300, 400',
        sizes: '180px',
        loading: 'lazy',
        alt: photo_settings.image_alt | default: photo_settings.image.alt,
        class: 'sgt-photo__image'
    }}
  </div>
{%- endif -%}

{% stylesheet %}
  .sgt-photo {
    flex-shrink: 0;
    width: var(--sgt-photo-size-mobile, 100px);
    height: var(--sgt-photo-size-mobile, 100px);
    padding: 6px 6px 16px;
    background-color: #ffffff;
    border-radius: 2px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.25);
    transform: rotate(var(--sgt-photo-rotate, 0deg));
    box-sizing: border-box;
  }

  .sgt-photo__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media screen and (min-width: 750px) {
    .sgt-photo {
      width: var(--sgt-photo-size-desktop, 180px);
      height: var(--sgt-photo-size-desktop, 180px);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Photo",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:settings.image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Alt text"
    },
    {
      "type": "range",
      "id": "rotation",
      "label": "Rotation",
      "min": -15,
      "max": 15,
      "step": 1,
      "unit": "deg",
      "default": -6
    }
  ],
  "presets": [
    {
      "name": "Photo"
    }
  ]
}
{% endschema %}
