        </svg>
      {%- endif -%}
    </div>
    <div class="results-timeline-item__labels">
      {%- if block_settings.period != blank -%}
        <div class="results-timeline-item__period">{{ block_settings.period }}</div>
      {%- endif -%}
      {%- if block_settings.subtitle != blank -%}
        <span class="results-timeline-item__subtitle">{{ block_settings.subtitle }}</span>
      {%- endif -%}
    </div>
  </div>

  {%- if block_settings.bullets != blank -%}
    <div class="results-timeline-item__bullets">{{ block_settings.bullets }}</div>
  {%- endif -%}
</div>

{% stylesheet %}
  .results-timeline-item {
    display: flex;
    flex-direction: column;
    gap: var(--rt-item-gap, 10px);
  }

  @media screen and (min-width: 990px) {
    .results-timeline-item {
      flex: 1 1 0%;
      min-width: 0;
      padding-right: var(--rt-items-row-gap, 32px);
    }

    .results-timeline-item:last-child {
      padding-right: 0;
    }
  }

  .results-timeline-item__header {
    display: flex;
    align-items: center;
    gap: var(--rt-item-header-gap, 10px);
  }

  .results-timeline-item__icon {
    flex-shrink: 0;
    width: var(--rt-icon-size-mobile, 56px);
    height: var(--rt-icon-size-mobile, 56px);
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(to bottom, var(--rt-icon-gradient-start, #e7b944), var(--rt-icon-gradient-end, #ffed68));
    border-radius: 50%;
    overflow: hidden;
    color: var(--rt-icon-color, #1a1a1a);
  }

  .results-timeline-item__icon-svg {
    width: 100%;
    height: 100%;
  }

  .results-timeline-item__icon-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .results-timeline-item__labels {
    display: flex;
    flex-direction: column;
  }

  .results-timeline-item__period {
    font-size: var(--rt-period-size-mobile, 16px);
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1.5;
  }

  .results-timeline-item__period p {
    margin: 0;
  }

  .results-timeline-item__period strong {
    color: var(--rt-accent-color, #e9be47);
  }

  @media screen and (min-width: 990px) {
    .results-timeline-item__period {
      font-size: var(--rt-period-size-desktop, 18px);
      line-height: 1.44;
    }

    .results-timeline-item__icon {
      width: var(--rt-icon-size-desktop, 56px);
      height: var(--rt-icon-size-desktop, 56px);
    }
  }

  .results-timeline-item__subtitle {
    display: block;
    font-size: var(--rt-subtitle-size, 18px);
    font-weight: 700;
    line-height: 1.44;
  }

  .results-timeline-item__bullets {
    font-size: var(--rt-bullets-size-mobile, 14px);
    line-height: 1.3;
  }

  .results-timeline-item__bullets :is(ul, ol) {
    list-style: disc;
    padding-left: 21px;
    margin: 0;
  }

  .results-timeline-item__bullets li {
    margin-bottom: var(--rt-bullets-gap-mobile, 4px);
  }

  .results-timeline-item__bullets li:last-child {
    margin-bottom: 0;
  }

  @media screen and (min-width: 990px) {
    .results-timeline-item__bullets {
      font-size: var(--rt-bullets-size-desktop, 16px);
      line-height: 1.25;
    }

    .results-timeline-item__bullets :is(ul, ol) {
      padding-left: 24px;
    }

    .results-timeline-item__bullets li {
      margin-bottom: var(--rt-bullets-gap-desktop, 8px);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Timeline item",
  "tag": null,
  "settings": [
    {
      "type": "richtext",
      "id": "period",
      "label": "Period label",
      "info": "Bold part of the text to highlight it in the accent color, e.g. \"Week **1**\".",
      "default": "<p>Week 1</p>"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Add a short milestone title"
    },
    {
      "type": "richtext",
      "id": "bullets",
      "label": "Bullet points",
      "default": "<ul><li>Add a result customers can expect</li><li>Add another result</li></ul>"
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "select",
      "id": "icon",
      "label": "Icon",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "lightning",
          "label": "Lightning bolt"
        },
        {
          "value": "star",
          "label": "Star badge"
        },
        {
          "value": "heart_pulse",
          "label": "Heart pulse"
        }
      ],
      "default": "lightning"
    },
    {
      "type": "image_picker",
      "id": "custom_icon",
      "label": "Custom icon image",
      "info": "Replaces the icon above when set."
    }
  ],
  "presets": [
    {
      "name": "Timeline item"
    }
  ]
}
{% endschema %}
