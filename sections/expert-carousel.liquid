{%- doc -%}
  Renders an "Expert carousel" section: a centered heading followed by a
  single-slide-at-a-time carousel of expert testimonials (circular photo,
  name, role and quote), stepped through with prev/next buttons. On desktop
  the photo and nav sit in a left column while the quote content sits beside
  them; on mobile everything stacks in a single column.

  Every expert is a nested "_expert-carousel-item" block, so merchants can
  add, remove or reorder them freely. All text, images, colors, sizes,
  spacing, navigation and autoplay are configurable through the section and
  block schemas.
{%- enddoc -%}

<script
  src="{{ 'expert-carousel.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{%- liquid
  assign section_settings = section.settings
  assign item_count = section.blocks.size

  if section_settings.background_color != blank
    render 'contrast-override', background_color: section_settings.background_color, section_id: section.id
  endif
-%}

<div
  class="section-background{% if section_settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
></div>

<div
  class="expert-carousel spacing-style{% if section_settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
  style="
    {% render 'spacing-style', settings: section_settings %}
    --ec-max-width: {{ section_settings.container_max_width }}px;
    --ec-edge-padding-mobile: {{ section_settings.container_padding_mobile }}px;
    --ec-edge-padding-desktop: {{ section_settings.container_padding_desktop }}px;
    --ec-heading-color: {{ section_settings.heading_color }};
    --ec-heading-size-mobile: {{ section_settings.heading_size_mobile }}px;
    --ec-heading-size-desktop: {{ section_settings.heading_size_desktop }}px;
    --ec-heading-gap-mobile: {{ section_settings.heading_gap_mobile }}px;
    --ec-heading-gap-desktop: {{ section_settings.heading_gap_desktop }}px;
    --ec-avatar-size-mobile: {{ section_settings.avatar_size_mobile }}px;
    --ec-avatar-size-desktop: {{ section_settings.avatar_size_desktop }}px;
    --ec-content-gap: {{ section_settings.content_gap }}px;
    --ec-name-color: {{ section_settings.name_color }};
    --ec-name-size: {{ section_settings.name_size }}px;
    --ec-role-color: {{ section_settings.role_color }};
    --ec-role-size: {{ section_settings.role_size }}px;
    --ec-quote-color: {{ section_settings.quote_color }};
    --ec-quote-size-mobile: {{ section_settings.quote_size_mobile }}px;
    --ec-quote-size-desktop: {{ section_settings.quote_size_desktop }}px;
    --ec-quote-mark-size: {{ section_settings.quote_mark_size }}px;
    --ec-nav-gap: {{ section_settings.nav_gap }}px;
    --ec-nav-btn-size: {{ section_settings.nav_button_size }}px;
    --ec-nav-icon-color: {{ section_settings.nav_icon_color }};
    --ec-nav-prev-bg: {{ section_settings.nav_prev_background }};
    --ec-nav-next-bg: {{ section_settings.nav_next_background }};
    --ec-wrapper-max-width: {{ section_settings.wrapper_max_width }}px;
    --ec-wrapper-gap-mobile: {{ section_settings.wrapper_gap_mobile }}px;
    --ec-wrapper-column-gap-desktop: {{ section_settings.wrapper_column_gap_desktop }}px;
    --ec-wrapper-row-gap-desktop: {{ section_settings.wrapper_row_gap_desktop }}px;
    {% if section_settings.background_color != blank %}
      --ec-bg: {{ section_settings.background_color }};
    {% endif %}
  "
  data-testid="expert-carousel"
>
  <div class="expert-carousel__container">
    {%- if section_settings.heading != blank -%}
      <h2 class="expert-carousel__heading">{{ section_settings.heading }}</h2>
    {%- endif -%}

    {%- if item_count > 0 -%}
      <expert-carousel-component
        class="expert-carousel__component"
        data-autoplay="{{ section_settings.autoplay }}"
        data-autoplay-speed="{{ section_settings.autoplay_speed }}"
      >
        <div class="expert-carousel__wrapper">
          {% content_for 'blocks' %}

          {%- if section_settings.show_nav and item_count > 1 -%}
            <div class="expert-carousel__nav">
              <button
                type="button"
                class="expert-carousel__btn expert-carousel__btn--prev expert-carousel__btn--disabled"
                ref="prevButton"
                on:click="/prev"
                aria-label="{{ 'accessibility.slideshow_previous' | t }}"
                aria-disabled="true"
              >
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 20 20"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                  aria-hidden="true"
                  focusable="false"
                >
                  <path
                    d="M12 5L7 10L12 15"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </button>
              <button
                type="button"
                class="expert-carousel__btn expert-carousel__btn--next"
                ref="nextButton"
                on:click="/next"
                aria-label="{{ 'accessibility.slideshow_next' | t }}"
                aria-disabled="false"
              >
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 20 20"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                  aria-hidden="true"
                  focusable="false"
                >
                  <path
                    d="M8 5L13 10L8 15"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </button>
            </div>
          {%- endif -%}
        </div>
      </expert-carousel-component>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .expert-carousel {
    width: 100%;
    overflow: hidden;
    background-color: var(--ec-bg, transparent);
  }

  .expert-carousel__container {
    max-width: var(--ec-max-width, 1440px);
    margin-inline: auto;
    padding-inline: var(--ec-edge-padding-mobile, 16px);
  }

  .expert-carousel__heading {
    font-size: var(--ec-heading-size-mobile, 24px);
    font-weight: 700;
    color: var(--ec-heading-color, currentColor);
    text-align: center;
    text-transform: uppercase;
    line-height: 1.3;
    margin: 0 0 var(--ec-heading-gap-mobile, 24px);
  }

  .expert-carousel__component {
    display: block;
  }

  .expert-carousel__wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--ec-wrapper-gap-mobile, 24px);
    max-width: var(--ec-wrapper-max-width, 884px);
    margin-inline: auto;
  }

  .expert-carousel__nav {
    display: flex;
    align-items: center;
    gap: var(--ec-nav-gap, 36px);
    justify-content: center;
  }

  .expert-carousel__btn {
    width: var(--ec-nav-btn-size, 40px);
    height: var(--ec-nav-btn-size, 40px);
    border-radius: 50%;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    color: var(--ec-nav-icon-color, #1a1a1a);
    transition: opacity 0.2s ease;
  }

  .expert-carousel__btn:hover:not(.expert-carousel__btn--disabled) {
    opacity: 0.7;
  }

  .expert-carousel__btn--disabled {
    opacity: 0.35;
    cursor: default;
    pointer-events: none;
  }

  .expert-carousel__btn svg {
    width: 50%;
    height: 50%;
    flex-shrink: 0;
  }

  .expert-carousel__btn--prev {
    background-color: var(--ec-nav-prev-bg, transparent);
  }

  .expert-carousel__btn--next {
    background-color: var(--ec-nav-next-bg, transparent);
  }

  @media screen and (min-width: 750px) {
    .expert-carousel__container {
      padding-inline: var(--ec-edge-padding-desktop, 120px);
    }
  }

  @media screen and (min-width: 990px) {
    .expert-carousel__heading {
      font-size: var(--ec-heading-size-desktop, 32px);
      margin-bottom: var(--ec-heading-gap-desktop, 40px);
    }

    .expert-carousel__wrapper {
      display: grid;
      grid-template-columns: auto 1fr;
      grid-template-areas: 'media content' 'nav content';
      column-gap: var(--ec-wrapper-column-gap-desktop, 60px);
      row-gap: var(--ec-wrapper-row-gap-desktop, 32px);
      align-items: start;
    }

    .expert-carousel__nav {
      grid-area: nav;
      justify-self: center;
      justify-content: flex-start;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Expert carousel",
  "class": "section-expert-carousel",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "_expert-carousel-item"
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "t:content.heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "Recommended by Men's Health Specialists"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "t:settings.text_color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size (mobile)",
      "min": 16,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading size (desktop)",
      "min": 20,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_gap_mobile",
      "label": "Space below heading (mobile)",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "heading_gap_desktop",
      "label": "Space below heading (desktop)",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "range",
      "id": "wrapper_max_width",
      "label": "Carousel max width",
      "min": 400,
      "max": 1200,
      "step": 8,
      "unit": "px",
      "default": 884
    },
    {
      "type": "range",
      "id": "wrapper_gap_mobile",
      "label": "Gap between blocks (mobile)",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "wrapper_column_gap_desktop",
      "label": "Column gap (desktop)",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "wrapper_row_gap_desktop",
      "label": "Row gap (desktop)",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "Photo"
    },
    {
      "type": "range",
      "id": "avatar_size_mobile",
      "label": "Photo size (mobile)",
      "min": 80,
      "max": 320,
      "step": 5,
      "unit": "px",
      "default": 210
    },
    {
      "type": "range",
      "id": "avatar_size_desktop",
      "label": "Photo size (desktop)",
      "min": 80,
      "max": 360,
      "step": 5,
      "unit": "px",
      "default": 210
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "Space between author and quote",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Name & role"
    },
    {
      "type": "color",
      "id": "name_color",
      "label": "Name color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "name_size",
      "label": "Name size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "role_color",
      "label": "Role color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "role_size",
      "label": "Role size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Quote"
    },
    {
      "type": "color",
      "id": "quote_color",
      "label": "t:settings.text_color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "quote_size_mobile",
      "label": "Quote size (mobile)",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "quote_size_desktop",
      "label": "Quote size (desktop)",
      "min": 10,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "quote_mark_size",
      "label": "Quote mark size",
      "min": 12,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 30
    },
    {
      "type": "header",
      "content": "t:content.navigation"
    },
    {
      "type": "checkbox",
      "id": "show_nav",
      "label": "t:settings.show",
      "default": true
    },
    {
      "type": "color",
      "id": "nav_icon_color",
      "label": "Icon color",
      "default": "#1a1a1a",
      "visible_if": "{{ section.settings.show_nav }}"
    },
    {
      "type": "color",
      "id": "nav_prev_background",
      "label": "Previous button background",
      "default": "#fcfaf5",
      "visible_if": "{{ section.settings.show_nav }}"
    },
    {
      "type": "color",
      "id": "nav_next_background",
      "label": "Next button background",
      "default": "#fcfaf5",
      "visible_if": "{{ section.settings.show_nav }}"
    },
    {
      "type": "range",
      "id": "nav_button_size",
      "label": "Button size",
      "min": 28,
      "max": 64,
      "step": 1,
      "unit": "px",
      "default": 40,
      "visible_if": "{{ section.settings.show_nav }}"
    },
    {
      "type": "range",
      "id": "nav_gap",
      "label": "t:settings.gap",
      "min": 8,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 36,
      "visible_if": "{{ section.settings.show_nav }}"
    },
    {
      "type": "header",
      "content": "Autoplay"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "t:settings.auto_rotate_slides",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "t:settings.speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5,
      "visible_if": "{{ section.settings.autoplay }}"
    },
    {
      "type": "header",
      "content": "t:content.size"
    },
    {
      "type": "range",
      "id": "container_max_width",
      "label": "Container max width",
      "min": 960,
      "max": 1800,
      "step": 20,
      "unit": "px",
      "default": 1440
    },
    {
      "type": "range",
      "id": "container_padding_mobile",
      "label": "Side padding (mobile)",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "container_padding_desktop",
      "label": "Side padding (desktop)",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "default": 120
    },
    {
      "type": "header",
      "content": "t:content.background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "default": "#fcfaf5"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Expert carousel",
      "category": "t:categories.product",
      "blocks": {
        "expert_1": {
          "type": "_expert-carousel-item",
          "settings": {
            "name": "Dr. Marcus Johnson",
            "role": "Sports Medicine & Male Performance Physician",
            "quote": "\"What I appreciate about the formulation in these gummies is the attention to circulatory health. Better circulation means better energy, better endurance, and better sexual responsiveness.\""
          }
        },
        "expert_2": {
          "type": "_expert-carousel-item",
          "settings": {
            "name": "Dr. Ethan Caldwell",
            "role": "Board-Certified Preventive Medicine Physician",
            "quote": "\"Most men's performance issues come down to circulation, desire, and mineral support failing at the same time. When you address all three at once, men don't just feel better, their performance improves too.\""
          }
        },
        "expert_3": {
          "type": "_expert-carousel-item",
          "settings": {
            "name": "Dr. James Whitfield",
            "role": "General Practitioner",
            "quote": "\"From a hormonal standpoint, the link between cortisol, testosterone, and daily stress is well documented. This formula addresses the hormonal foundation most men never think to support.\""
          }
        }
      },
      "block_order": ["expert_1", "expert_2", "expert_3"]
    }
  ]
}
{% endschema %}
