    {
      "type": "range",
      "id": "feature_title_size_mobile",
      "label": "Feature title size (mobile)",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "feature_text_size_desktop",
      "label": "Feature text size (desktop)",
      "min": 10,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "feature_text_size_mobile",
      "label": "Feature text size (mobile)",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "t:content.image"
    },
    {
