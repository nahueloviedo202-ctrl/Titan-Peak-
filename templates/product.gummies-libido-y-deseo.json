                    },
                    "product_info_faq_item_wHTXPq": {
                      "type": "_product-info-faq-item",
                      "settings": {
                        "question": "¿TITAN PEAK está testeado por terceros?",
                        "answer": "<p>Sí. Cada lote se fabrica en una instalación que cumple con las Buenas Prácticas de Fabricación (BPF) y se somete a pruebas de calidad, pureza y seguridad realizadas por terceros. Creemos que usted debe saber exactamente qué consume.</p>"
                      },
                      "blocks": {}
                    },
                    "product_info_faq_item_JpDpAC": {
                      "type": "_product-info-faq-item",
                      "settings": {
                        "question": "¿Para quién es TITAN PEAK?",
                        "answer": "<p>TITAN PEAK está diseñado para hombres que desean potenciar su energía, concentración, vitalidad, confianza y rendimiento general. Ya sea que compagines el trabajo, el ejercicio, la vida familiar o las tres cosas, TITAN PEAK está formulado para ayudarte a rendir al máximo cada día.</p>"
