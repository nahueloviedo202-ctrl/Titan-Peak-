    {
      "type": "header",
      "content": "t:content.carousel"
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "label": "t:settings.columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "tablet_columns",
      "label": "Tablet columns",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "mobile_slide_width",
      "label": "Mobile slide width",
      "min": 50,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 85
    },
    {
      "type": "range",
      "id": "items_gap_desktop",
      "label": "Gap (tablet & desktop)",
      "min": 0,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "items_gap_mobile",
      "label": "Gap (mobile)",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 16
