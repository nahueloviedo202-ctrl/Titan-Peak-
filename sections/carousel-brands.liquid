{%- doc -%}
  Renders a "carousel brands" section: an optional centered heading (e.g. "As
  seen in:") followed by an infinitely scrolling row of brand/press logos.

  Reuses the theme's native `marquee-component` custom element (assets/marquee.js,
  already shipped with `sections/marquee.liquid`) for the seamless, auto-duplicating
  scroll behavior with pointer pause — no extra JavaScript is added by this section.

  Every logo is a nested "_carousel-brands-logo" block, so merchants can add,
  remove or reorder them freely. All text, colors, sizes, spacing, gap, scroll
  direction, speed and autoplay are configurable through the section schema.
{%- enddoc -%}

<script
  src="{{ 'marquee.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{%- liquid
  assign section_settings = section.settings

  if section_settings.background_color != blank
    render 'contrast-override', background_color: section_settings.background_color, section_id: section.id
  endif
-%}

<div
  class="section-background{% if section_settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
></div>

<div
  class="carousel-brands spacing-style{% if section_settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
  style="
    {% render 'spacing-style', settings: section_settings %}
    --carousel-brands-heading-color: {{ section_settings.heading_color }};
    --carousel-brands-heading-size-mobile: {{ section_settings.heading_size_mobile }}px;
    --carousel-brands-heading-size-desktop: {{ section_settings.heading_size_desktop }}px;
    --carousel-brands-heading-gap: {{ section_settings.heading_gap }}px;
    --carousel-brands-gap-mobile: {{ section_settings.gap_mobile }}px;
    --carousel-brands-gap-desktop: {{ section_settings.gap_desktop }}px;
    --carousel-brands-gap: var(--carousel-brands-gap-mobile);
    --marquee-direction: {{ section_settings.movement_direction }};
  "
  data-testid="carousel-brands"
>
  {%- if section_settings.heading != blank -%}
    <h2 class="carousel-brands__heading">{{ section_settings.heading }}</h2>
  {%- endif -%}

  <marquee-component
    class="carousel-brands__marquee"
    data-speed-factor="{{ section_settings.speed_factor }}"
    data-movement-direction="{{ section_settings.movement_direction }}"
    {% unless section_settings.enable_animation %}
      data-disabled
    {% endunless %}
  >
    <div
      class="marquee__wrapper"
      ref="wrapper"
    >
      <div
        class="marquee__content"
        ref="content"
      >
        <div
          class="marquee__repeated-items"
          ref="marqueeItems[]"
        >
          {% content_for 'blocks' %}
        </div>
      </div>
    </div>
  </marquee-component>
</div>

{% stylesheet %}
  .carousel-brands {
    display: flex;
    flex-direction: column;
    background-color: transparent;
  }

  .carousel-brands__heading {
    margin: 0 0 var(--carousel-brands-heading-gap, 20px);
    color: var(--carousel-brands-heading-color, var(--color-foreground));
    font-size: var(--carousel-brands-heading-size-mobile, 16px);
    font-weight: 400;
    line-height: 1.2;
    text-align: center;
  }

  .carousel-brands__marquee {
    display: block;
    width: 100%;
    overflow: hidden;
  }

  .carousel-brands__marquee .marquee__wrapper {
    display: flex;
    gap: var(--carousel-brands-gap);
    width: fit-content;
    white-space: nowrap;
  }

  .carousel-brands__marquee .marquee__content {
    min-width: max-content;
    display: flex;
    gap: var(--carousel-brands-gap);
  }

  .carousel-brands__marquee .marquee__repeated-items {
    min-width: max-content;
    display: flex;
    gap: var(--carousel-brands-gap);
    align-items: center;
    justify-content: center;
  }

  .carousel-brands__marquee .marquee__repeated-items > * {
    align-content: center;
    max-width: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .carousel-brands__marquee:not([data-disabled]) .marquee__wrapper {
      animation: carousel-brands-marquee-motion var(--marquee-speed, 30s) linear infinite var(--marquee-direction, normal);
    }
  }

  @keyframes carousel-brands-marquee-motion {
    to {
      transform: translate3d(calc(-50% - (var(--carousel-brands-gap) / 2)), 0, 0);
    }
  }

  @media screen and (min-width: 750px) {
    .carousel-brands__heading {
      font-size: var(--carousel-brands-heading-size-desktop, 22px);
    }

    .carousel-brands {
      --carousel-brands-gap: var(--carousel-brands-gap-desktop);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Carousel brands",
  "class": "section-carousel-brands",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "_carousel-brands-logo"
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "t:content.heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "As seen in:"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "t:settings.text_color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size (mobile)",
      "min": 10,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading size (desktop)",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "heading_gap",
      "label": "Space below heading",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Carousel"
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Gap between logos (mobile)",
      "min": 0,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "label": "Gap between logos (desktop)",
      "min": 0,
      "max": 240,
      "step": 2,
      "unit": "px",
      "default": 100
    },
    {
      "type": "select",
      "id": "movement_direction",
      "label": "t:settings.motion_direction",
      "options": [
        {
          "value": "normal",
          "label": "t:options.forward"
        },
        {
          "value": "reverse",
          "label": "t:options.reverse"
        }
      ],
      "default": "normal"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "Autoplay scrolling",
      "default": true
    },
    {
      "type": "range",
      "id": "speed_factor",
      "label": "Speed",
      "info": "Lower values scroll faster",
      "min": 10,
      "max": 60,
      "step": 5,
      "default": 30
    },
    {
      "type": "header",
      "content": "t:content.background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "placeholder": "t:settings.default"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Carousel brands",
      "category": "t:categories.decorative",
      "settings": {
        "background_color": "#141414",
        "heading_color": "#ffffff"
      },
      "blocks": {
        "brand_1": {
          "type": "_carousel-brands-logo"
        },
        "brand_2": {
          "type": "_carousel-brands-logo"
        },
        "brand_3": {
          "type": "_carousel-brands-logo"
        },
        "brand_4": {
          "type": "_carousel-brands-logo"
        },
        "brand_5": {
          "type": "_carousel-brands-logo"
        }
      },
      "block_order": ["brand_1", "brand_2", "brand_3", "brand_4", "brand_5"]
    }
  ]
}
{% endschema %}
