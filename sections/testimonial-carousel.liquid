      "step": 1,
      "unit": "s",
      "default": 5,
      "visible_if": "{{ section.settings.autoplay }}"
    },
    {
      "type": "header",
      "content": "t:content.navigation"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "t:settings.show",
      "default": true
    },
    {
      "type": "color",
      "id": "arrow_icon_color",
