{%- doc -%}
  Renders a single step of the results-timeline section: an icon badge, a
  period label (e.g. "Week 1"), a subtitle and a list of bullet points.

  Meant to be used exclusively as a child block of `sections/results-timeline.liquid`.
{%- enddoc -%}

{% assign block_settings = block.settings %}

<div
  class="results-timeline-item"
  {{ block.shopify_attributes }}
>
  <div class="results-timeline-item__header">
    <div class="results-timeline-item__icon">
      {%- if block_settings.custom_icon != blank -%}
        {{
          block_settings.custom_icon
          | image_url: width: 160
          | image_tag: width: 56, height: 56, loading: 'lazy', alt: '', class: 'results-timeline-item__icon-image'
        }}
      {%- elsif block_settings.icon != 'none' -%}
        <svg
          class="results-timeline-item__icon-svg"
          aria-hidden="true"
          focusable="false"
          xmlns="http://www.w3.org/2000/svg"
