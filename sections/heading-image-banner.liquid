{%- doc -%}
  Renders a "heading + image" banner: a heading followed by a single large
  image, optionally art-directed with a separate image for mobile, sitting on
  top of an optional decorative background color/image.

  No repeatable content here (a single heading + a single image), so this
  section intentionally has no blocks — every text, image, color, size,
  spacing, radius and alignment value is configurable through the schema.
{%- enddoc -%}

{%- liquid
  assign section_settings = section.settings
  assign has_mobile_image = false
  if section_settings.image_mobile != blank
    assign has_mobile_image = true
  endif

  if section_settings.background_color != blank
    render 'contrast-override', background_color: section_settings.background_color, section_id: section.id
  endif
-%}

<div
  class="section-background{% if section_settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
  {% if section_settings.background_image != blank %}
    style="
      background-image: url({{ section_settings.background_image | image_url: width: 1920 }});
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    "
  {% endif %}
></div>

<div
  class="heading-image-banner spacing-style{% if section_settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
  style="
    {% render 'spacing-style', settings: section_settings %}
    --hib-padding-block-mobile: {{ section_settings.padding_block_mobile }}px;
    --hib-padding-inline-mobile: {{ section_settings.padding_inline_mobile }}px;
    --hib-padding-block-desktop: {{ section_settings.padding_block_desktop }}px;
    --hib-padding-inline-desktop: {{ section_settings.padding_inline_desktop }}px;
    --hib-heading-color: {{ section_settings.heading_color }};
    --hib-heading-size-mobile: {{ section_settings.heading_size_mobile }}px;
    --hib-heading-size-desktop: {{ section_settings.heading_size_desktop }}px;
    --hib-heading-weight: {{ section_settings.heading_weight }};
    --hib-heading-letter-spacing: {{ section_settings.heading_letter_spacing }}px;
    --hib-heading-max-width: {{ section_settings.heading_max_width }}px;
    --hib-heading-gap: {{ section_settings.heading_gap }}px;
    --hib-image-max-width: {{ section_settings.image_max_width }}px;
    --hib-image-radius: {{ section_settings.image_radius }}px;
  "
  data-testid="heading-image-banner"
>
  {%- if section_settings.heading != blank -%}
    <div class="heading-image-banner__heading-wrapper heading-image-banner__heading-wrapper--{{ section_settings.heading_alignment }}">
      <h2 class="heading-image-banner__heading">{{ section_settings.heading }}</h2>
    </div>
  {%- endif -%}

  {%- if section_settings.image_desktop != blank or has_mobile_image -%}
    <div class="heading-image-banner__image">
      {%- if has_mobile_image -%}
        {{
          section_settings.image_mobile
          | image_url: width: 1200
          | image_tag:
            loading: 'lazy',
            widths: '400, 600, 800, 1200',
            sizes: '(min-width: 768px) 0px, 100vw',
            alt: section_settings.image_mobile.alt | default: section_settings.heading,
            class: 'heading-image-banner__img heading-image-banner__img--mobile'
        }}
        {{
          section_settings.image_desktop
          | default: section_settings.image_mobile
          | image_url: width: 2560
          | image_tag:
            loading: 'lazy',
            widths: '800, 1200, 1600, 2000, 2560',
            sizes: '(min-width: 768px) 100vw, 0px',
            alt: section_settings.image_desktop.alt | default: section_settings.heading,
            class: 'heading-image-banner__img heading-image-banner__img--desktop'
        }}
      {%- else -%}
        {{
          section_settings.image_desktop
          | image_url: width: 2560
          | image_tag:
            loading: 'lazy',
            widths: '400, 600, 800, 1200, 1600, 2000, 2560',
            sizes: '100vw',
            alt: section_settings.image_desktop.alt | default: section_settings.heading,
            class: 'heading-image-banner__img'
        }}
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

{% stylesheet %}
  .heading-image-banner {
    display: flex;
    flex-direction: column;
    background-color: transparent;
    padding: var(--hib-padding-block-mobile, 24px) var(--hib-padding-inline-mobile, 12px);
  }

  .heading-image-banner__heading-wrapper {
    max-width: var(--hib-heading-max-width, 720px);
    margin-bottom: var(--hib-heading-gap, 32px);
  }

  .heading-image-banner__heading-wrapper--center {
    margin-inline: auto;
    text-align: center;
  }

  .heading-image-banner__heading-wrapper--left {
    margin-inline: 0 auto;
    text-align: left;
  }

  .heading-image-banner__heading-wrapper--right {
    margin-inline: auto 0;
    text-align: right;
  }

  .heading-image-banner__heading {
    margin: 0;
    color: var(--hib-heading-color, #24222a);
    font-size: var(--hib-heading-size-mobile, 32px);
    font-weight: var(--hib-heading-weight, 700);
    line-height: 1.3;
    letter-spacing: var(--hib-heading-letter-spacing, -0.64px);
  }

  .heading-image-banner__image {
    display: flex;
    justify-content: center;
    align-items: center;
    max-width: var(--hib-image-max-width, 1100px);
    margin-inline: auto;
    width: 100%;
  }

  .heading-image-banner__img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--hib-image-radius, 0px);
  }

  .heading-image-banner__img--mobile {
    display: block;
  }

  .heading-image-banner__img--desktop {
    display: none;
  }

  @media screen and (min-width: 768px) {
    .heading-image-banner {
      padding: var(--hib-padding-block-desktop, 60px) var(--hib-padding-inline-desktop, 60px);
    }

    .heading-image-banner__heading {
      font-size: var(--hib-heading-size-desktop, 36px);
    }

    .heading-image-banner__img--mobile {
      display: none;
    }

    .heading-image-banner__img--desktop {
      display: block;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Heading image banner",
  "class": "section-heading-image-banner",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:content.heading"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "<p>Why Thousands of Customers Worldwide Trust Our Brand over Others</p>"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:settings.alignment",
      "options": [
        {
          "value": "left",
          "label": "t:options.left"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "right",
          "label": "t:options.right"
        }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "t:settings.text_color",
      "default": "#24222a"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size (mobile)",
      "min": 16,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading size (desktop)",
      "min": 20,
      "max": 64,
      "step": 1,
      "unit": "px",
      "default": 36
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "t:settings.weight",
      "options": [
        {
          "value": "400",
          "label": "t:options.regular"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semibold"
        },
        {
          "value": "700",
          "label": "t:options.bold"
        },
        {
          "value": "800",
          "label": "800"
        }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "heading_letter_spacing",
      "label": "Letter spacing",
      "min": -2,
      "max": 2,
      "step": 0.1,
      "unit": "px",
      "default": -0.64
    },
    {
      "type": "range",
      "id": "heading_max_width",
      "label": "Heading max width",
      "min": 320,
      "max": 1200,
      "step": 10,
      "unit": "px",
      "default": 720
    },
    {
      "type": "range",
      "id": "heading_gap",
      "label": "Space below heading",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "t:content.image"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Image (tablet & desktop)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Image (mobile)",
      "info": "Optional. Falls back to the image above when empty."
    },
    {
      "type": "range",
      "id": "image_max_width",
      "label": "Image max width",
      "min": 400,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1100
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "t:settings.corner_radius",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "range",
      "id": "padding_block_mobile",
      "label": "Vertical padding (mobile)",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_inline_mobile",
      "label": "Side padding (mobile)",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_block_desktop",
      "label": "Vertical padding (desktop)",
      "min": 0,
      "max": 140,
      "step": 2,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_inline_desktop",
      "label": "Side padding (desktop)",
      "min": 0,
      "max": 140,
      "step": 2,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "t:content.background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "default": "#f7f7f7"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "t:content.background_image"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Heading image banner",
      "category": "t:categories.banners"
    }
  ]
}
{% endschema %}
