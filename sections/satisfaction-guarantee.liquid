  ],
  "presets": [
    {
      "name": "Satisfaction guarantee",
      "category": "t:categories.product",
      "blocks": {
        "photos": {
          "type": "_satisfaction-guarantee-photos",
          "static": true
        },
        "benefits": {
          "type": "_satisfaction-guarantee-benefits",
          "static": true
        }
      }
    }
  ]
}
{% endschema %}
