{%- doc -%}
  Renders a footer link column: a bold heading followed by a stack of
  "_footer-link" rows. Every link is its own nested block, so merchants can
  add, remove or reorder them freely.

  Colors, sizes and spacing are controlled by the parent section via CSS
  custom properties. Meant to be used exclusively as a child block of
  `sections/footer-custom.liquid`.
{%- enddoc -%}

{%- liquid
  assign menu_settings = block.settings
  assign link_count = block.blocks.size
-%}

<div
  class="footer-columns__block footer-columns__block--menu"
  {{ block.shopify_attributes }}
>
  {%- if menu_settings.heading != blank -%}
    <p class="footer-columns__heading">{{ menu_settings.heading }}</p>
  {%- endif -%}

  {%- if link_count > 0 -%}
    <ul class="footer-columns__link-list">
      {% content_for 'blocks' %}
    </ul>
  {%- endif -%}
</div>

{% stylesheet %}
  .footer-columns__block--menu {
    max-width: var(--fc-menu-max-width, 250px);
  }

  .footer-columns__link-list {
    display: flex;
    flex-direction: column;
    gap: var(--fc-link-gap, 12px);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .footer-columns__link {
    display: inline-block;
    color: inherit;
    text-decoration: none;
    opacity: var(--fc-link-opacity, 0.7);
    transition: opacity 0.2s ease;
    overflow-wrap: break-word;
  }

  .footer-columns__link:hover {
    opacity: 1;
  }

  .footer-columns__link--disabled {
    cursor: default;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Footer menu",
  "tag": null,
  "blocks": [
    {
      "type": "_footer-link"
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "Menu"
    }
  ],
  "presets": [
    {
      "name": "Footer menu",
      "blocks": {
        "link_1": {
          "type": "_footer-link",
          "settings": {
            "label": "Link"
          }
        }
      },
      "block_order": ["link_1"]
    }
  ]
}
{% endschema %}
