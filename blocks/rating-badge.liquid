{%- doc -%}
  Rating badge: a row of star icons followed by a short line of rich text
  (e.g. "Rated 4.5/5 by Thousands of Customers"). Purely presentational —
  the stars and copy are set by the merchant, not pulled from live review data.
{%- enddoc -%}

{%- liquid
  assign badge_settings = block.settings
  assign icon_count = badge_settings.icon_count | default: 5

  assign justify_align = 'flex-start'
  if badge_settings.width == '100%'
    case badge_settings.alignment
      when 'center'
        assign justify_align = 'center'
      when 'right'
        assign justify_align = 'flex-end'
      else
        assign justify_align = 'flex-start'
    endcase
  endif
-%}

<div
  class="rating-badge spacing-style"
  style="
    {% render 'spacing-style', settings: badge_settings %}
    --rating-badge-align: {{ justify_align }};
    --rating-badge-icon-color: {{ badge_settings.icon_color }};
    --rating-badge-icon-size: {{ badge_settings.icon_size }}px;
    --rating-badge-icon-gap: {{ badge_settings.icon_gap }}px;
    --rating-badge-content-gap: {{ badge_settings.content_gap }}px;
  "
  {{ block.shopify_attributes }}
>
  <svg
    class="visually-hidden"
    style="width: 0; height: 0;"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 32 32"
    role="presentation"
  >
    <defs>
      <symbol
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 32 32"
        id="rating-badge-star-{{ block.id }}"
      >
        <path
          d="M31.547 12a.848.848 0 00-.677-.577l-9.427-1.376-4.224-8.532a.847.847 0 00-1.516 0l-4.218 8.534-9.427 1.355a.847.847 0 00-.467 1.467l6.823 6.664-1.612 9.375a.847.847 0 001.23.893l8.428-4.434 8.432 4.432a.847.847 0 001.229-.894l-1.615-9.373 6.822-6.665a.845.845 0 00.214-.869z"
        />
      </symbol>
    </defs>
  </svg>

  {%- if icon_count > 0 -%}
    <div
      class="rating-badge__stars"
      aria-hidden="true"
    >
      {%- for i in (1..icon_count) -%}
        <svg
          class="rating-badge__star"
          viewBox="0 0 32 32"
          role="presentation"
        >
          <use xlink:href="#rating-badge-star-{{ block.id }}"></use>
        </svg>
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- render 'text', block: block, class: 'rating-badge__text' -%}
</div>

{% stylesheet %}
  .rating-badge {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    justify-content: var(--rating-badge-align, flex-start);
    column-gap: var(--rating-badge-content-gap);
    row-gap: calc(var(--rating-badge-content-gap) / 2);
  }

  .rating-badge__stars {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    gap: var(--rating-badge-icon-gap);
  }

  .rating-badge__star {
    width: var(--rating-badge-icon-size);
    height: var(--rating-badge-icon-size);
    flex-shrink: 0;
    fill: var(--rating-badge-icon-color);
  }

  .rating-badge__text {
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Rating badge",
  "tag": null,
  "settings": [
    {
      "type": "richtext",
      "id": "text",
      "label": "t:settings.text",
      "default": "<p>Rated <strong>4.5/5</strong> by <strong>Thousands of Customers</strong></p>"
    },
    {
      "type": "header",
      "content": "Stars"
    },
    {
      "type": "range",
      "id": "icon_count",
      "label": "Number of stars",
      "min": 0,
      "max": 10,
      "step": 1,
      "default": 5
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Star color",
      "default": "#FF4C01"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Star size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 18,
      "visible_if": "{{ block.settings.icon_count > 0 }}"
    },
    {
      "type": "range",
      "id": "icon_gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 2,
      "visible_if": "{{ block.settings.icon_count > 0 }}"
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "Content spacing",
      "min": 0,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 8,
      "visible_if": "{{ block.settings.icon_count > 0 }}"
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "fit-content",
          "label": "t:options.fit"
        },
        {
          "value": "100%",
          "label": "t:options.fill"
        }
      ],
      "default": "fit-content"
    },
    {
      "type": "select",
      "id": "max_width",
      "label": "t:settings.max_width",
      "options": [
        {
          "value": "narrow",
          "label": "t:options.narrow"
        },
        {
          "value": "normal",
          "label": "t:options.normal"
        },
        {
          "value": "none",
          "label": "t:options.none"
        }
      ],
      "default": "normal"
    },
    {
      "type": "text_alignment",
      "id": "alignment",
      "label": "t:settings.alignment",
      "default": "left",
      "visible_if": "{{ block.settings.width == '100%' }}"
    },
    {
      "type": "header",
      "content": "t:content.typography"
    },
    {
      "type": "select",
      "id": "type_preset",
      "label": "t:settings.preset",
      "options": [
        {
          "value": "rte",
          "label": "t:options.default"
        },
        {
          "value": "paragraph",
          "label": "t:options.paragraph"
        },
        {
          "value": "h1",
          "label": "t:options.h1"
        },
        {
          "value": "h2",
          "label": "t:options.h2"
        },
        {
          "value": "h3",
          "label": "t:options.h3"
        },
        {
          "value": "h4",
          "label": "t:options.h4"
        },
        {
          "value": "h5",
          "label": "t:options.h5"
        },
        {
          "value": "h6",
          "label": "t:options.h6"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "paragraph",
      "info": "t:info.edit_presets_in_theme_settings"
    },
    {
      "type": "select",
      "id": "font",
      "label": "t:settings.font",
      "options": [
        {
          "value": "var(--font-body--family)",
          "label": "t:options.body"
        },
        {
          "value": "var(--font-subheading--family)",
          "label": "t:options.subheading"
        },
        {
          "value": "var(--font-heading--family)",
          "label": "t:options.heading"
        },
        {
          "value": "var(--font-accent--family)",
          "label": "t:options.accent"
        }
      ],
      "default": "var(--font-body--family)",
      "visible_if": "{{ block.settings.type_preset == 'custom' }}"
    },
    {
      "type": "select",
      "id": "font_size",
      "label": "t:settings.size",
      "options": [
        {
          "value": "",
          "label": "t:options.default"
        },
        {
          "value": "0.625rem",
          "label": "10px"
        },
        {
          "value": "0.75rem",
          "label": "12px"
        },
        {
          "value": "0.875rem",
          "label": "14px"
        },
        {
          "value": "1rem",
          "label": "16px"
        },
        {
          "value": "1.125rem",
          "label": "18px"
        },
        {
          "value": "1.25rem",
          "label": "20px"
        },
        {
          "value": "1.5rem",
          "label": "24px"
        }
      ],
      "default": "1rem",
      "visible_if": "{{ block.settings.type_preset == 'custom' }}"
    },
    {
      "type": "select",
      "id": "line_height",
      "label": "t:settings.line_height",
      "options": [
        {
          "value": "tight",
          "label": "t:options.tight"
        },
        {
          "value": "normal",
          "label": "t:options.normal"
        },
        {
          "value": "loose",
          "label": "t:options.loose"
        }
      ],
      "default": "normal",
      "visible_if": "{{ block.settings.type_preset == 'custom' }}"
    },
    {
      "type": "select",
      "id": "letter_spacing",
      "label": "t:settings.letter_spacing",
      "options": [
        {
          "value": "tight",
          "label": "t:options.tight"
        },
        {
          "value": "normal",
          "label": "t:options.normal"
        },
        {
          "value": "loose",
          "label": "t:options.loose"
        }
      ],
      "default": "normal",
      "visible_if": "{{ block.settings.type_preset == 'custom' }}"
    },
    {
      "type": "select",
      "id": "case",
      "label": "t:settings.case",
      "options": [
        {
          "value": "none",
          "label": "t:options.default"
        },
        {
          "value": "uppercase",
          "label": "t:options.uppercase"
        }
      ],
      "default": "none",
      "visible_if": "{{ block.settings.type_preset == 'custom' }}"
    },
    {
      "type": "select",
      "id": "wrap",
