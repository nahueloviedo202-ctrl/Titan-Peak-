{%- doc -%}
  Renders a "Cards grid" section: a centered header (heading with an
  optional gradient accent word + subheading) followed by a responsive grid
  of cards, each showing an image next to (or above) a title and
  description.

  Every card is a nested "_cards-grid-item" block, so merchants can add,
  remove or reorder cards freely. Column counts, gaps, image size/position,
  colors, sizes, spacing and radius are all configurable through the section
  and block schemas. This is a static grid (not a carousel), so autoplay,
  slide count and transition speed settings do not apply here.
{%- enddoc -%}

{%- liquid
  assign section_settings = section.settings
  assign card_count = section.blocks.size
-%}

<div class="section-background"></div>

<div
  class="cards-grid"
  style="
    --cg-max-width: {{ section_settings.container_max_width }}px;
    --cg-radius: {{ section_settings.corner_radius }}px;
    --cg-pad-top: {{ section_settings.padding_top }}px;
    --cg-pad-right: {{ section_settings.padding_right }}px;
    --cg-pad-bottom: {{ section_settings.padding_bottom }}px;
    --cg-pad-left: {{ section_settings.padding_left }}px;
    --cg-heading-color: {{ section_settings.heading_color }};
    --cg-heading-size-mobile: {{ section_settings.heading_size_mobile }}px;
    --cg-heading-size-desktop: {{ section_settings.heading_size_desktop }}px;
    --cg-accent-gradient-start: {{ section_settings.heading_accent_gradient_start }};
    --cg-accent-gradient-end: {{ section_settings.heading_accent_gradient_end }};
    --cg-subtitle-color: {{ section_settings.subtitle_color }};
    --cg-subtitle-size-mobile: {{ section_settings.subtitle_size_mobile }}px;
    --cg-subtitle-size-desktop: {{ section_settings.subtitle_size_desktop }}px;
    --cg-header-gap-mobile: {{ section_settings.header_gap_mobile }}px;
    --cg-header-gap-desktop: {{ section_settings.header_gap_desktop }}px;
    --cg-columns-mobile: {{ section_settings.columns_mobile }};
    --cg-columns-tablet: {{ section_settings.columns_tablet }};
    --cg-columns-desktop: {{ section_settings.columns_desktop }};
    --cg-gap-mobile: {{ section_settings.grid_gap_mobile }}px;
    --cg-gap-tablet: {{ section_settings.grid_gap_tablet }}px;
    --cg-gap-desktop: {{ section_settings.grid_gap_desktop }}px;
    --cg-card-bg: {{ section_settings.card_background_color }};
    --cg-card-border-color: {{ section_settings.card_border_color }};
    --cg-card-border-width: {{ section_settings.card_border_width }}px;
    --cg-card-radius: {{ section_settings.card_border_radius }}px;
    --cg-image-radius: {{ section_settings.card_image_radius }}px;
    --cg-image-inset: {{ section_settings.card_image_inset }}px;
    --cg-image-size-mobile: {{ section_settings.card_image_size_mobile }}px;
    --cg-image-size-tablet: {{ section_settings.card_image_size_tablet }}px;
    --cg-image-size-desktop: {{ section_settings.card_image_size_desktop }}px;
    --cg-title-color: {{ section_settings.card_title_color }};
    --cg-title-size-mobile: {{ section_settings.card_title_size_mobile }}px;
    --cg-title-size-desktop: {{ section_settings.card_title_size_desktop }}px;
    --cg-description-color: {{ section_settings.card_description_color }};
    --cg-description-size-mobile: {{ section_settings.card_description_size_mobile }}px;
    --cg-description-size-desktop: {{ section_settings.card_description_size_desktop }}px;
    --cg-content-padding-mobile: {{ section_settings.card_content_padding_mobile }}px;
    --cg-content-padding-tablet: {{ section_settings.card_content_padding_tablet }}px;
    --cg-content-padding-desktop: {{ section_settings.card_content_padding_desktop }}px;
    {% if section_settings.background_color != blank %}
      --cg-bg: {{ section_settings.background_color }};
    {% endif %}
  "
  data-testid="cards-grid"
>
  <div class="cards-grid__container">
    {%- if section_settings.heading != blank or section_settings.subtitle != blank -%}
      <header class="cards-grid__header">
        {%- if section_settings.heading != blank -%}
          <h2 class="cards-grid__heading">{{ section_settings.heading }}</h2>
        {%- endif -%}

        {%- if section_settings.subtitle != blank -%}
          <div class="cards-grid__subtitle rte">{{ section_settings.subtitle }}</div>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- if card_count > 0 -%}
      <div class="cards-grid__items">
        {% content_for 'blocks' %}
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .cards-grid {
    width: 100%;
    background: var(--cg-bg, #1c3353);
    border-radius: var(--cg-radius, 0px);
    padding: var(--cg-pad-top, 30px) var(--cg-pad-right, 20px) var(--cg-pad-bottom, 60px) var(--cg-pad-left, 20px);
  }

  .cards-grid__container {
    max-width: var(--cg-max-width, 1200px);
    margin: 0 auto;
  }

  .cards-grid__header {
    text-align: center;
    margin-bottom: var(--cg-header-gap-mobile, 40px);
  }

  .cards-grid__heading {
    margin: 0 0 8px;
    color: var(--cg-heading-color, #ffffff);
    font-size: var(--cg-heading-size-mobile, 36px);
    font-weight: var(--font-weight-bold, 700);
    line-height: 1.2;
  }

  .cards-grid__heading strong {
    font-weight: inherit;
    background: linear-gradient(180deg, var(--cg-accent-gradient-start, #b8b8b8), var(--cg-accent-gradient-end, #ffffff));
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .cards-grid__subtitle {
    color: var(--cg-subtitle-color, #ffffff);
    font-size: var(--cg-subtitle-size-mobile, 16px);
    opacity: 0.85;
  }

  .cards-grid__items {
    display: grid;
    grid-template-columns: repeat(var(--cg-columns-mobile, 1), 1fr);
    gap: var(--cg-gap-mobile, 15px);
    align-items: stretch;
  }

  @media screen and (min-width: 750px) {
    .cards-grid__header {
      margin-bottom: var(--cg-header-gap-desktop, 60px);
    }

    .cards-grid__heading {
      font-size: var(--cg-heading-size-desktop, 52px);
    }

    .cards-grid__subtitle {
      font-size: var(--cg-subtitle-size-desktop, 18px);
    }

    .cards-grid__items {
      grid-template-columns: repeat(var(--cg-columns-tablet, 4), 1fr);
      gap: var(--cg-gap-tablet, 18px);
    }
  }

  @media screen and (min-width: 990px) {
    .cards-grid__items {
      grid-template-columns: repeat(var(--cg-columns-desktop, 2), 1fr);
      gap: var(--cg-gap-desktop, 25px);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Cards grid",
  "class": "section-cards-grid",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "_cards-grid-item"
