{%- doc -%}
  Renders a stack of independent, collapsible accordion cards (title +
  content), each with its own rounded background — replicating the PDP
  "Product details / Ingredients / Shipping & Returns" info accordion.

  Product information block: add it inside the product details column,
  alongside blocks like description, disclosures or wellness benefits.
  Add one or more "Accordion item" child blocks to populate it.

  Every text, color, size, spacing, radius and icon style is configurable
  through the block and child block schemas. Reuses the theme's native
  `accordion-custom` component for the expand/collapse behavior, so no
  extra JavaScript is added.
{%- enddoc -%}

{% liquid
  assign block_settings = block.settings
%}

{% capture style %}
  {%- render 'spacing-style', settings: block_settings -%}
  --ag-item-gap: {{ block_settings.item_gap }}px;
  --ag-card-bg: {{ block_settings.card_background_color }};
  --ag-card-radius: {{ block_settings.card_radius }}px;
  --ag-trigger-padding-block: {{ block_settings.trigger_padding_block }}px;
  --ag-trigger-padding-inline: {{ block_settings.trigger_padding_inline }}px;
  --ag-trigger-gap: {{ block_settings.trigger_gap }}px;
  --ag-trigger-hover-bg: {{ block_settings.trigger_hover_color }};
  --ag-focus-color: {{ block_settings.focus_color }};
  --ag-icon-size: {{ block_settings.icon_size }}px;
  --ag-icon-color: {{ block_settings.icon_color }};
  --ag-title-size: {{ block_settings.title_size }}px;
  --ag-title-weight: {{ block_settings.title_weight }};
  --ag-title-color: {{ block_settings.title_color }};
  --ag-content-padding: {{ block_settings.content_padding }}px;
  --ag-content-size: {{ block_settings.content_size }}px;
  --ag-content-line-height: {{ block_settings.content_line_height }};
  --ag-content-color: {{ block_settings.content_color }};
  --ag-transition-speed: {{ block_settings.transition_speed }}ms;
{% endcapture %}

<div
  class="accordion-group accordion-group--{{ block_settings.icon_style }} spacing-style"
  style="{{ style }}"
  data-testid="accordion-group"
  {{ block.shopify_attributes }}
>
  {% content_for 'blocks' %}
</div>

{% stylesheet %}
  .accordion-group {
    display: flex;
    flex-direction: column;
    gap: var(--ag-item-gap, 24px);
  }

  .accordion-group--chevron .icon-plus,
  .accordion-group--plus .icon-caret {
    display: none;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Accordion group",
  "tag": null,
  "blocks": [
    {
      "type": "_accordion-item"
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "item_gap",
      "label": "Spacing between items",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Card"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "t:settings.background_color",
      "default": "#fcfaf5"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "t:settings.corner_radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Trigger"
    },
    {
      "type": "range",
      "id": "trigger_padding_block",
      "label": "Trigger padding (top/bottom)",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "trigger_padding_inline",
      "label": "Trigger padding (left/right)",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "trigger_gap",
      "label": "Spacing between title and icon",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "trigger_hover_color",
      "label": "Hover background",
      "alpha": true,
      "default": "#00000008"
    },
    {
      "type": "color",
      "id": "focus_color",
      "label": "Focus outline color",
      "default": "#a45b2c"
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "select",
      "id": "icon_style",
      "label": "Icon style",
      "options": [
        {
          "value": "chevron",
          "label": "Chevron"
        },
        {
          "value": "plus",
          "label": "Plus / minus"
        }
      ],
      "default": "chevron"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 16,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#212529"
    },
    {
      "type": "header",
      "content": "Title typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Title weight",
      "options": [
        {
          "value": "400",
          "label": "Regular"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semibold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "500"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Content typography"
    },
    {
      "type": "range",
      "id": "content_padding",
      "label": "Content padding",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "content_size",
      "label": "Content text size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "content_line_height",
      "label": "Content line height",
      "min": 1.0,
      "max": 2.0,
      "step": 0.1,
      "default": 1.6
    },
    {
      "type": "color",
      "id": "content_color",
      "label": "Content text color",
      "default": "#212529"
    },
    {
      "type": "header",
      "content": "Interaction"
    },
    {
      "type": "range",
      "id": "transition_speed",
      "label": "Transition speed",
      "min": 100,
      "max": 600,
      "step": 50,
      "unit": "ms",
      "default": 250
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Accordion group",
      "category": "t:categories.product",
      "blocks": {
        "item_1": {
          "type": "_accordion-item",
          "settings": {
            "title": "Product details",
            "content": "<p>UltimaPeak® Performance Gummies are a pure, lab-tested, and natural solution for men to maintain peak physical performance, mental clarity, vitality, and stamina</p>"
          }
        },
        "item_2": {
          "type": "_accordion-item",
          "settings": {
            "title": "Ingredients",
            "content": "<p>• <strong>Ashwagandha KSM-66®</strong> supports in decreasing cortisol by up to 27.9%, helping you stay relaxed, confident, and fully present.<br>• <strong>L-Arginine and Saffron</strong> are proven to help enhancing nitric oxide production and circulation, ensuring strong, lasting erections.<br>• <strong>Shilajit Extract</strong> plus <strong>Maca</strong> and <strong>Saffron</strong> both contribute to the increase of total and free testosterone and support healthy sperm quality.</p>"
          }
        },
        "item_3": {
          "type": "_accordion-item",
          "settings": {
            "title": "Shipping & Returns",
            "content": "<p>• <strong>Free Shipping:</strong> We offer free standard shipping on all orders.<br>• <strong>Delivery Area:</strong> We currently ship within the United States. Orders typically arrive within <strong>5 days</strong> after processing, depending on the destination.<br><br>We accept returns under the following conditions:<br>• <strong>Return Window:</strong> Items must be returned within 14 days of delivery.<br>• <strong>Item Condition:</strong> Items must be unused, unopened, and in their original packaging.<br>• <strong>Proof of Purchase:</strong> A receipt or order number is required for all returns.</p>"
          }
        }
      },
      "block_order": ["item_1", "item_2", "item_3"]
    }
  ]
}
{% endschema %}
