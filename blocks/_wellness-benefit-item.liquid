{% stylesheet %}
  .wellness-benefit-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--wb-item-gap, 10px);
  }

  .wellness-benefit-item__icon {
    flex-shrink: 0;
    width: var(--wb-icon-size-mobile, 38px);
    height: var(--wb-icon-size-mobile, 38px);
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(180deg, var(--wb-icon-gradient-start, #e7b944), var(--wb-icon-gradient-end, #ffed68));
    border-radius: var(--wb-icon-radius, 50%);
    overflow: hidden;
    color: var(--wb-icon-color, #1a1a1a);
  }

  .wellness-benefit-item__icon-svg {
    width: 100%;
    height: 100%;
    display: block;
    flex-shrink: 0;
  }

  .wellness-benefit-item__icon-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .wellness-benefit-item__text {
    margin: 0;
    font-size: var(--wb-text-size, 16px);
    line-height: 1.25;
    color: var(--wb-text-color, #1a1a1a);
    text-align: center;
  }

  @media screen and (min-width: 990px) {
    .wellness-benefit-item__icon {
      width: var(--wb-icon-size-desktop, 44px);
      height: var(--wb-icon-size-desktop, 44px);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Benefit item",
  "tag": null,
  "settings": [
    {
      "type": "select",
      "id": "icon",
      "label": "Icon",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "heart_pulse",
          "label": "Heart pulse"
        },
        {
          "value": "lightning",
          "label": "Lightning bolt"
        },
        {
          "value": "focus",
          "label": "Focus target"
        },
        {
          "value": "star",
          "label": "Star badge"
        }
      ],
      "default": "heart_pulse"
    },
    {
      "type": "image_picker",
      "id": "custom_icon",
      "label": "Custom icon image",
      "info": "Replaces the icon above when set."
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Supports vitality and wellness"
    }
  ],
  "presets": [
    {
      "name": "Benefit item"
    }
  ]
}
{% endschema %}
