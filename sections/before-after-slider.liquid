{%- doc -%}
  Renders a "before/after slider" section: a centered header (heading with an
  optional accent word + subheading) followed by optional category filter
  buttons and an arrow/dot-controlled carousel of before/after image pairs.

  Every before/after pair is a nested "_before-after-slide" block, so
  merchants can add, remove or reorder results freely. All text, images,
  colors, sizes, spacing, radius, column counts, autoplay and speed are
  configurable through the section and block schemas.
{%- enddoc -%}

<script
  src="{{ 'before-after-slider.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{%- liquid
  assign section_settings = section.settings
  assign slide_count = section.blocks.size

  if section_settings.background_color != blank
    render 'contrast-override', background_color: section_settings.background_color, section_id: section.id
  endif

  case section_settings.image_ratio
    when 'square'
      assign image_ratio = '1 / 1'
    when 'landscape'
      assign image_ratio = '4 / 3'
    else
      assign image_ratio = '4 / 5'
  endcase

  assign category_handles = '|~|'
  assign category_labels = ''
  for block in section.blocks
    assign raw_category = block.settings.category | strip
    if raw_category != blank
      assign handle = raw_category | handleize
      assign needle = handle | prepend: '|~|' | append: '|~|'
      if handle != blank
        unless category_handles contains needle
          assign category_handles = category_handles | append: handle | append: '|~|'
          assign category_labels = category_labels | append: raw_category | append: '|~|'
        endunless
      endif
    endif
  endfor
  assign category_handle_list = category_handles | remove_first: '|~|' | split: '|~|'
  assign category_label_list = category_labels | split: '|~|'
-%}

<div
  class="section-background{% if section_settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
></div>

<div
  class="before-after spacing-style{% if section_settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
  style="
    {% render 'spacing-style', settings: section_settings %}
    --ba-max-width: {{ section_settings.container_max_width }}px;
    --ba-header-gap-mobile: {{ section_settings.header_gap_mobile }}px;
    --ba-header-gap-desktop: {{ section_settings.header_gap_desktop }}px;
    --ba-heading-color: {{ section_settings.heading_color }};
    --ba-heading-accent-color: {{ section_settings.heading_accent_color }};
    --ba-heading-size-mobile: {{ section_settings.heading_size_mobile }}px;
    --ba-heading-size-desktop: {{ section_settings.heading_size_desktop }}px;
    --ba-subheading-color: {{ section_settings.subheading_color }};
    --ba-subheading-size: {{ section_settings.subheading_size }}px;
    --ba-filter-bg: {{ section_settings.filter_bg_color }};
    --ba-filter-text: {{ section_settings.filter_text_color }};
    --ba-filter-border-color: {{ section_settings.filter_border_color }};
    --ba-filter-active-bg: {{ section_settings.filter_active_bg_color }};
    --ba-filter-active-text: {{ section_settings.filter_active_text_color }};
    --ba-filter-active-border-color: {{ section_settings.filter_active_border_color }};
    --ba-filter-radius: {{ section_settings.filter_radius }}px;
    --ba-columns: {{ section_settings.desktop_columns }};
    --ba-columns-tablet: {{ section_settings.tablet_columns }};
    --ba-mobile-slide-width: {{ section_settings.mobile_slide_width }}%;
    --ba-items-gap: {{ section_settings.items_gap_desktop }}px;
    --ba-items-gap-mobile: {{ section_settings.items_gap_mobile }}px;
    --ba-images-gap: {{ section_settings.images_gap }}px;
    --ba-image-ratio: {{ image_ratio }};
    --ba-image-radius: {{ section_settings.image_radius }}px;
    --ba-image-border-width: {{ section_settings.image_border_width }}px;
    --ba-image-border-color: {{ section_settings.image_border_color }};
    --ba-card-bg: {{ section_settings.card_background_color }};
    --ba-card-radius: {{ section_settings.card_radius }}px;
    --ba-card-padding: {{ section_settings.card_padding }}px;
    --ba-before-label-bg: {{ section_settings.before_label_bg_color }};
    --ba-before-label-text: {{ section_settings.before_label_text_color }};
    --ba-after-label-bg: {{ section_settings.after_label_bg_color }};
    --ba-after-label-text: {{ section_settings.after_label_text_color }};
    --ba-label-radius: {{ section_settings.label_radius }}px;
    --ba-label-font-size: {{ section_settings.label_font_size }}px;
    --ba-arrow-bg: {{ section_settings.arrow_bg_color }};
    --ba-arrow-text: {{ section_settings.arrow_icon_color }};
    --ba-arrow-border-color: {{ section_settings.arrow_border_color }};
    --ba-arrow-hover-bg: {{ section_settings.arrow_hover_bg_color }};
    --ba-arrow-hover-text: {{ section_settings.arrow_hover_icon_color }};
    --ba-arrow-hover-border-color: {{ section_settings.arrow_hover_border_color }};
    --ba-arrow-size: {{ section_settings.arrow_size }}px;
    --ba-arrow-border-width: {{ section_settings.arrow_border_width }}px;
    --ba-arrow-radius: {{ section_settings.arrow_radius }}px;
    --ba-arrow-gap: {{ section_settings.arrow_gap }}px;
    --ba-dot-color: {{ section_settings.dot_color }};
    --ba-dot-active-color: {{ section_settings.dot_active_color }};
    --ba-dot-size: {{ section_settings.dot_size }}px;
    --ba-dot-gap: {{ section_settings.dot_gap }}px;
    {% if section_settings.background_color != blank %}
      --ba-bg: {{ section_settings.background_color }};
    {% endif %}
  "
  data-testid="before-after-slider"
>
  <div class="before-after__container">
    {%- if section_settings.heading != blank or section_settings.subheading != blank -%}
      <header class="before-after__header">
        {%- if section_settings.heading != blank -%}
          <h2 class="before-after__heading">{{ section_settings.heading }}</h2>
        {%- endif -%}

        {%- if section_settings.subheading != blank -%}
          <div class="before-after__subheading">{{ section_settings.subheading }}</div>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- if section_settings.show_filters and category_handle_list.size > 0 -%}
      <div
        class="before-after__filters"
        role="group"
        aria-label="{{ section_settings.filter_group_label }}"
      >
        <button
          type="button"
          class="before-after__filter is-active"
          ref="filterButton[]"
          data-category="all"
          on:click="/filter/all"
          aria-pressed="true"
        >
          {{- section_settings.all_filter_label -}}
        </button>

        {%- for handle in category_handle_list -%}
          <button
            type="button"
            class="before-after__filter"
            ref="filterButton[]"
            data-category="ba-{{ handle }}"
            on:click="/filter/ba-{{ handle }}"
            aria-pressed="false"
          >
            {{- category_label_list[forloop.index0] -}}
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if slide_count > 0 -%}
      <before-after-slider-component
        class="before-after__component"
        data-autoplay="{{ section_settings.autoplay }}"
        data-autoplay-speed="{{ section_settings.autoplay_speed }}"
      >
        <div
          class="before-after__wrapper"
          ref="wrapper"
        >
          <div
            class="before-after__track"
            ref="track"
          >
            {% content_for 'blocks' %}
          </div>
        </div>

        <div class="before-after__controls">
          {%- if section_settings.show_arrows and slide_count > 1 -%}
            <button
              type="button"
              class="before-after__arrow before-after__arrow--prev"
              ref="prevButton"
              on:click="/prev"
              aria-label="{{ 'accessibility.slideshow_previous' | t }}"
            >
              {{- 'icon-chevron-left.svg' | inline_asset_content -}}
            </button>
          {%- endif -%}

          {%- if section_settings.show_pagination and slide_count > 1 -%}
            <div
              class="before-after__pagination"
              ref="pagination"
              role="tablist"
              aria-label="{{ section_settings.pagination_label }}"
            ></div>
          {%- endif -%}

          {%- if section_settings.show_arrows and slide_count > 1 -%}
            <button
              type="button"
              class="before-after__arrow before-after__arrow--next"
              ref="nextButton"
              on:click="/next"
              aria-label="{{ 'accessibility.slideshow_next' | t }}"
            >
              {{- 'icon-chevron-right.svg' | inline_asset_content -}}
            </button>
          {%- endif -%}
        </div>
      </before-after-slider-component>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .before-after {
    width: 100%;
    overflow: hidden;
    background-color: var(--ba-bg, transparent);
  }

  .before-after__container {
    max-width: var(--ba-max-width, 1400px);
    margin: 0 auto;
  }

  .before-after__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    text-align: center;
    margin-bottom: var(--ba-header-gap-mobile, 24px);
  }

  .before-after__heading {
    margin: 0;
    color: var(--ba-heading-color, currentColor);
    font-size: var(--ba-heading-size-mobile, 28px);
    font-weight: 700;
    line-height: 1.2;
  }

  .before-after__heading strong {
    color: var(--ba-heading-accent-color, currentColor);
    font-weight: inherit;
  }

  .before-after__subheading {
    max-width: 600px;
    color: var(--ba-subheading-color, currentColor);
    font-size: var(--ba-subheading-size, 16px);
    line-height: 1.5;
  }

  .before-after__filters {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin: 0 auto var(--ba-header-gap-mobile, 24px);
    max-width: 800px;
  }

  .before-after__filter {
    padding: 7px 18px;
    background-color: var(--ba-filter-bg, #f5f5f5);
    color: var(--ba-filter-text, #333333);
    border: 2px solid var(--ba-filter-border-color, #e0e0e0);
    border-radius: var(--ba-filter-radius, 8px);
    font-size: 13px;
    font-weight: 600;
    line-height: 1.4;
    white-space: nowrap;
    cursor: pointer;
    transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease, transform 0.3s ease;
  }

  .before-after__filter:hover {
    transform: translateY(-2px);
  }

  .before-after__filter.is-active {
    background-color: var(--ba-filter-active-bg, #121212);
    color: var(--ba-filter-active-text, #ffffff);
    border-color: var(--ba-filter-active-border-color, #121212);
  }

  .before-after__component {
    display: block;
    width: 100%;
  }

  .before-after__wrapper {
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  .before-after__track {
    display: flex;
    gap: var(--ba-items-gap-mobile, 16px);
    transition: transform 0.3s ease-in-out;
    will-change: transform;
  }

  .before-after__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--ba-arrow-gap, 20px);
    margin-top: 28px;
  }

  .before-after__arrow {
    flex-shrink: 0;
    width: var(--ba-arrow-size, 40px);
    height: var(--ba-arrow-size, 40px);
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--ba-arrow-bg, #ffffff);
    color: var(--ba-arrow-text, #000000);
    border: var(--ba-arrow-border-width, 1px) solid var(--ba-arrow-border-color, #e0e0e0);
    border-radius: var(--ba-arrow-radius, 50px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    cursor: pointer;
    transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease, transform 0.3s ease, opacity 0.3s ease;
  }

  .before-after__arrow:hover:not(:disabled) {
    background-color: var(--ba-arrow-hover-bg, #eaeaea);
    color: var(--ba-arrow-hover-text, #000000);
    border-color: var(--ba-arrow-hover-border-color, #cccccc);
    transform: translateY(-2px);
  }

  .before-after__arrow:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  .before-after__arrow svg {
    width: 40%;
    height: 40%;
    display: block;
    pointer-events: none;
  }

  .before-after__pagination {
    display: flex;
    align-items: center;
    gap: var(--ba-dot-gap, 8px);
  }

  .before-after__pagination:empty {
    display: none;
  }

  .before-after__dot {
    width: var(--ba-dot-size, 8px);
    height: var(--ba-dot-size, 8px);
    padding: 0;
    border: none;
    border-radius: 50%;
    background-color: var(--ba-dot-color, #cccccc);
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.3s ease;
  }

  .before-after__dot:hover {
    transform: scale(1.2);
  }

  .before-after__dot.is-active {
    background-color: var(--ba-dot-active-color, #121212);
    transform: scale(1.3);
  }

  @media screen and (min-width: 750px) {
    .before-after__track {
      gap: var(--ba-items-gap, 24px);
    }
  }

  @media screen and (min-width: 990px) {
    .before-after__header {
      margin-bottom: var(--ba-header-gap-desktop, 40px);
    }

    .before-after__filters {
      margin-bottom: var(--ba-header-gap-desktop, 40px);
    }

    .before-after__heading {
      font-size: var(--ba-heading-size-desktop, 42px);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Before/after slider",
  "class": "section-before-after-slider",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "_before-after-slide"
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "t:content.heading"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "t:settings.heading",
      "info": "Wrap a word in bold to color it with the accent color below.",
      "default": "<p>See the Amazing <strong>Transformations</strong></p>"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "t:settings.text_color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "heading_accent_color",
      "label": "Accent color",
      "default": "#c9a84c"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size (mobile)",
      "min": 16,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading size (desktop)",
      "min": 20,
      "max": 64,
      "step": 1,
      "unit": "px",
      "default": 42
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "t:names.subheading",
      "default": "<p>See the amazing transformations and results from our customers.</p>"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "t:settings.text_color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "t:settings.size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "header_gap_mobile",
      "label": "Space below header (mobile)",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "header_gap_desktop",
      "label": "Space below header (desktop)",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 30
    },
    {
      "type": "header",
      "content": "Category filters"
    },
    {
      "type": "checkbox",
      "id": "show_filters",
      "label": "t:settings.show",
      "info": "Filter buttons are generated automatically from each slide's category. They only appear when at least one slide has a category.",
      "default": true
    },
    {
      "type": "text",
      "id": "all_filter_label",
      "label": "\"Show all\" button label",
      "default": "All",
      "visible_if": "{{ section.settings.show_filters }}"
    },
    {
      "type": "text",
      "id": "filter_group_label",
      "label": "Accessibility label",
      "default": "Filter results by category",
      "visible_if": "{{ section.settings.show_filters }}"
    },
    {
      "type": "color",
      "id": "filter_bg_color",
      "label": "t:settings.background_color",
      "default": "#f5f5f5",
      "visible_if": "{{ section.settings.show_filters }}"
    },
    {
      "type": "color",
      "id": "filter_text_color",
      "label": "t:settings.text_color",
      "default": "#333333",
      "visible_if": "{{ section.settings.show_filters }}"
    },
    {
      "type": "color",
      "id": "filter_border_color",
      "label": "t:settings.border_color",
      "default": "#e0e0e0",
      "visible_if": "{{ section.settings.show_filters }}"
    },
    {
      "type": "color",
      "id": "filter_active_bg_color",
      "label": "Active background",
      "default": "#121212",
      "visible_if": "{{ section.settings.show_filters }}"
    },
    {
      "type": "color",
      "id": "filter_active_text_color",
      "label": "Active text color",
      "default": "#ffffff",
      "visible_if": "{{ section.settings.show_filters }}"
    },
    {
      "type": "color",
      "id": "filter_active_border_color",
      "label": "Active border color",
      "default": "#121212",
      "visible_if": "{{ section.settings.show_filters }}"
    },
    {
      "type": "range",
      "id": "filter_radius",
      "label": "t:settings.corner_radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 8,
      "visible_if": "{{ section.settings.show_filters }}"
    },
    {
      "type": "header",
      "content": "t:content.carousel"
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "label": "t:settings.columns",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "tablet_columns",
      "label": "Tablet columns",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "mobile_slide_width",
      "label": "Mobile slide width",
      "min": 60,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "items_gap_desktop",
      "label": "Gap between slides (tablet & desktop)",
      "min": 0,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "items_gap_mobile",
      "label": "Gap between slides (mobile)",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Autoplay"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "t:settings.auto_rotate_slides",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "t:settings.speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5,
      "visible_if": "{{ section.settings.autoplay }}"
    },
    {
      "type": "header",
      "content": "t:content.navigation"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show arrows",
      "default": true
    },
    {
      "type": "color",
      "id": "arrow_bg_color",
      "label": "Background",
      "default": "#ffffff",
      "visible_if": "{{ section.settings.show_arrows }}"
    },
    {
      "type": "color",
      "id": "arrow_icon_color",
      "label": "Icon color",
      "default": "#000000",
      "visible_if": "{{ section.settings.show_arrows }}"
    },
    {
      "type": "color",
      "id": "arrow_border_color",
      "label": "t:settings.border_color",
      "default": "#e0e0e0",
      "visible_if": "{{ section.settings.show_arrows }}"
    },
    {
      "type": "color",
      "id": "arrow_hover_bg_color",
      "label": "Hover background",
      "default": "#eaeaea",
      "visible_if": "{{ section.settings.show_arrows }}"
    },
    {
      "type": "color",
      "id": "arrow_hover_icon_color",
      "label": "Hover icon color",
      "default": "#000000",
      "visible_if": "{{ section.settings.show_arrows }}"
    },
    {
      "type": "color",
      "id": "arrow_hover_border_color",
      "label": "Hover border color",
      "default": "#cccccc",
      "visible_if": "{{ section.settings.show_arrows }}"
    },
    {
      "type": "range",
      "id": "arrow_size",
      "label": "t:settings.size",
      "min": 28,
      "max": 56,
      "step": 1,
      "unit": "px",
      "default": 40,
      "visible_if": "{{ section.settings.show_arrows }}"
    },
    {
      "type": "range",
      "id": "arrow_border_width",
      "label": "t:settings.thickness",
      "min": 0,
      "max": 6,
      "step": 1,
      "unit": "px",
      "default": 1,
      "visible_if": "{{ section.settings.show_arrows }}"
    },
    {
      "type": "range",
      "id": "arrow_radius",
      "label": "t:settings.corner_radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 50,
      "visible_if": "{{ section.settings.show_arrows }}"
    },
    {
      "type": "range",
      "id": "arrow_gap",
      "label": "t:settings.gap",
      "min": 8,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": "Show pagination dots",
      "default": true
    },
    {
      "type": "text",
      "id": "pagination_label",
      "label": "Accessibility label",
      "default": "Slide navigation",
      "visible_if": "{{ section.settings.show_pagination }}"
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "t:settings.color",
      "default": "#cccccc",
      "visible_if": "{{ section.settings.show_pagination }}"
    },
    {
      "type": "color",
      "id": "dot_active_color",
      "label": "Active color",
      "default": "#121212",
      "visible_if": "{{ section.settings.show_pagination }}"
    },
    {
