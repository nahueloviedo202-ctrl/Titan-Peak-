      "min": 32,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "icon_size_desktop",
      "label": "Badge size (desktop)",
      "min": 40,
      "max": 120,
      "step": 1,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "icon_inner_size_mobile",
      "label": "Icon size (mobile)",
      "min": 12,
      "max": 56,
      "step": 1,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "icon_inner_size_desktop",
      "label": "Icon size (desktop)",
      "min": 12,
      "max": 64,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
