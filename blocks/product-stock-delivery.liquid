{%- doc -%}
  Product stock & delivery: a centered row showing a live inventory status
  (pulsing dot + "In stock" / "Low stock" / "Out of stock", driven by the
  same inventory logic and translation keys as the theme's native
  `product-inventory` block) next to a delivery-estimate note with an icon.

  No merchant-facing repeatable list here (same as the native
  `product-inventory` block it borrows its inventory logic from), so this
  is a single, self-contained block.
{%- enddoc -%}

{%- liquid
  assign block_settings = block.settings
  assign variant = closest.product.selected_or_first_available_variant

  if variant.inventory_management == 'shopify'
    assign inventory_managed = true
  endif
  assign inventory_quantity = variant.inventory_quantity
  assign inventory_policy = variant.inventory_policy
  assign threshold = block_settings.inventory_threshold
  assign show_quantity = false

  if inventory_managed
    if inventory_quantity > 0
      if inventory_quantity <= threshold
        assign stock_status = 'low'
        assign show_quantity = block_settings.show_inventory_quantity
        unless show_quantity
          assign stock_translation_key = 'content.inventory_low_stock'
        endunless
      else
        assign stock_status = 'in_stock'
        assign stock_translation_key = 'content.inventory_in_stock'
      endif
    else
      if inventory_policy == 'continue'
        assign stock_status = 'in_stock'
        assign stock_translation_key = 'content.inventory_in_stock'
      else
        assign stock_status = 'out_of_stock'
        assign stock_translation_key = 'content.inventory_out_of_stock'
      endif
    endif
  elsif variant != null
    assign stock_status = 'in_stock'
    assign stock_translation_key = 'content.inventory_in_stock'
  else
    assign stock_status = 'out_of_stock'
    assign stock_translation_key = 'content.inventory_out_of_stock'
  endif
-%}

<div
  class="product-stock-delivery spacing-style"
  style="
    {% render 'spacing-style', settings: block_settings %}
    --psd-gap: {{ block_settings.gap }}px;
    --psd-alignment: {{ block_settings.alignment }};
    --psd-font-size-desktop: {{ block_settings.font_size_desktop }}px;
    --psd-font-size-mobile: {{ block_settings.font_size_mobile }}px;
    --psd-icon-size: {{ block_settings.delivery_icon_size }}px;
    {% if block_settings.text_color != blank %}--psd-text-color: {{ block_settings.text_color }};{% endif %}
    {% if block_settings.in_stock_color != blank %}--psd-color-in-stock: {{ block_settings.in_stock_color }};{% endif %}
    {% if block_settings.low_stock_color != blank %}--psd-color-low-stock: {{ block_settings.low_stock_color }};{% endif %}
    {% if block_settings.out_of_stock_color != blank %}--psd-color-out-of-stock: {{ block_settings.out_of_stock_color }};{% endif %}
  "
  {{ block.shopify_attributes }}
>
  {%- if block_settings.show_stock and closest.product != blank -%}
    <span class="product-stock-delivery__stock">
      <span
        class="
          product-stock-delivery__dot
          product-stock-delivery__dot--{{ stock_status }}
          {% if block_settings.pulse_animation and stock_status == 'in_stock' %}product-stock-delivery__dot--pulse{% endif %}
        "
        aria-hidden="true"
      ></span>
      <span role="status">
        {%- if show_quantity -%}
          {{ 'content.inventory_low_stock_show_count' | t: count: inventory_quantity }}
        {%- else -%}
          {{- stock_translation_key | t -}}
        {%- endif -%}
      </span>
    </span>
  {%- endif -%}

  {%- if block_settings.show_delivery and block_settings.delivery_text != blank -%}
    <span class="product-stock-delivery__delivery">
      {%- if block_settings.delivery_icon != blank -%}
        {{
          block_settings.delivery_icon
          | image_url: width: 48
          | image_tag: loading: 'lazy', width: 24, height: 24, alt: '', class: 'product-stock-delivery__icon'
        }}
      {%- else -%}
        <svg
          class="product-stock-delivery__icon"
          viewBox="0 0 24 24"
          fill="none"
          aria-hidden="true"
          focusable="false"
        >
          <path
            d="M2 6.5C2 5.67157 2.67157 5 3.5 5H13.5C14.3284 5 15 5.67157 15 6.5V15H2.5C2.22386 15 2 14.7761 2 14.5V6.5Z"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linejoin="round"
          />
          <path
            d="M15 9H18.4384C18.7815 9 19.0932 9.19893 19.2384 9.50986L20.8 12.8571V15H15V9Z"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linejoin="round"
          />
          <circle
            cx="7"
            cy="17.5"
            r="1.75"
            stroke="currentColor"
            stroke-width="1.5"
          />
          <circle
            cx="17"
            cy="17.5"
            r="1.75"
            stroke="currentColor"
            stroke-width="1.5"
          />
        </svg>
      {%- endif -%}
      {{ block_settings.delivery_text }}
    </span>
  {%- endif -%}
</div>

{% stylesheet %}
  .product-stock-delivery {
    display: flex;
    align-items: center;
    justify-content: var(--psd-alignment, center);
    flex-wrap: wrap;
    gap: var(--psd-gap, 20px);
  }

  .product-stock-delivery__stock,
  .product-stock-delivery__delivery {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-size: var(--psd-font-size-desktop, 14px);
    font-weight: 500;
    color: var(--psd-text-color, #1a1a1a);
  }

  .product-stock-delivery__dot {
    width: 10px;
    height: 10px;
    flex-shrink: 0;
    border-radius: 50%;
  }

  .product-stock-delivery__dot--in_stock {
    background-color: var(--psd-color-in-stock, var(--color-instock, #00cb35));
  }

  .product-stock-delivery__dot--low {
    background-color: var(--psd-color-low-stock, var(--color-lowstock, #e7b944));
  }

  .product-stock-delivery__dot--out_of_stock {
    background-color: var(--psd-color-out-of-stock, var(--color-outofstock, #999999));
  }

  .product-stock-delivery__dot--pulse {
    animation: product-stock-delivery-pulse 1.5s ease-in-out infinite;
  }

  .product-stock-delivery__icon {
    width: var(--psd-icon-size, 24px);
    height: var(--psd-icon-size, 24px);
    flex-shrink: 0;
    color: var(--psd-text-color, #1a1a1a);
  }

  @keyframes product-stock-delivery-pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 1;
    }

    50% {
      transform: scale(1.2);
      opacity: 0.7;
    }
  }

  @media screen and (max-width: 749px) {
    .product-stock-delivery__stock,
    .product-stock-delivery__delivery {
      font-size: var(--psd-font-size-mobile, 11px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .product-stock-delivery__dot--pulse {
      animation: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product stock & delivery",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Stock status"
    },
    {
      "type": "checkbox",
      "id": "show_stock",
      "label": "t:settings.show",
      "default": true
    },
    {
      "type": "range",
      "id": "inventory_threshold",
      "label": "t:settings.inventory_threshold",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 10,
      "visible_if": "{{ block.settings.show_stock }}"
    },
    {
      "type": "checkbox",
      "id": "show_inventory_quantity",
      "label": "t:settings.show_inventory_quantity",
      "default": false,
      "visible_if": "{{ block.settings.show_stock }}"
    },
    {
      "type": "checkbox",
      "id": "pulse_animation",
      "label": "Pulse animation",
      "default": true,
      "visible_if": "{{ block.settings.show_stock }}"
    },
    {
      "type": "color",
      "id": "in_stock_color",
      "label": "In stock color",
      "placeholder": "t:settings.default",
      "visible_if": "{{ block.settings.show_stock }}"
    },
    {
      "type": "color",
      "id": "low_stock_color",
      "label": "Low stock color",
      "placeholder": "t:settings.default",
      "visible_if": "{{ block.settings.show_stock }}"
    },
    {
      "type": "color",
      "id": "out_of_stock_color",
      "label": "Out of stock color",
      "placeholder": "t:settings.default",
      "visible_if": "{{ block.settings.show_stock }}"
    },
    {
      "type": "header",
      "content": "Delivery estimate"
    },
    {
      "type": "checkbox",
      "id": "show_delivery",
      "label": "t:settings.show",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "delivery_icon",
      "label": "t:settings.icon",
      "info": "Falls back to a built-in truck icon when empty.",
      "visible_if": "{{ block.settings.show_delivery }}"
    },
    {
      "type": "range",
      "id": "delivery_icon_size",
      "label": "t:settings.size",
      "min": 12,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 24,
      "visible_if": "{{ block.settings.show_delivery }}"
    },
    {
      "type": "text",
      "id": "delivery_text",
      "label": "t:settings.text",
      "default": "Expected delivery in 3 to 6 business days",
      "visible_if": "{{ block.settings.show_delivery }}"
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:settings.alignment",
      "options": [
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-start",
          "label": "t:options.left"
        },
        {
          "value": "space-between",
          "label": "t:options.space_between"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "font_size_desktop",
      "label": "Text size (tablet & desktop)",
      "min": 8,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "Text size (mobile)",
      "min": 8,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 11
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:settings.text_color",
      "placeholder": "t:settings.default"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Product stock & delivery",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
