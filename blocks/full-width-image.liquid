{%- doc -%}
  Renders an edge-to-edge, full-width image with optional art direction:
  a different image can be shown on mobile than on desktop, instead of
  just a cropped/resized version of the same picture.

  An optional link can wrap the image. Sizes, radius, spacing and colors
  are configurable through the block schema.
{%- enddoc -%}

{% assign block_settings = block.settings %}

{% liquid
  assign desktop_image = block_settings.image
  assign mobile_image = block_settings.mobile_image
  assign has_art_direction = false
  if desktop_image != blank and mobile_image != blank
    assign has_art_direction = true
  endif

  assign primary_image = desktop_image | default: mobile_image
  assign alt_text = block_settings.alt | default: primary_image.alt

  assign widths = '240, 352, 500, 750, 1100, 1500, 1780, 2000, 3000, 3840'
  assign mobile_widths_array = '240, 352, 500, 750, 1100, 1500' | split: ', '
  assign sizes = 'auto, 100vw'
%}

{% capture style %}
  --fwi-radius: {{ block_settings.border_radius }}px;
  {%- render 'spacing-style', settings: block_settings -%}
{% endcapture %}

{% capture media %}
  {%- if has_art_direction -%}
    <picture>
      <source
        media="(max-width: 749px)"
        srcset="
          {%- for mobile_width in mobile_widths_array -%}
            {{- mobile_image | image_url: width: mobile_width }} {{ mobile_width }}w{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        "
        sizes="100vw"
        width="{{ mobile_image.width }}"
        height="{{ mobile_image.height }}"
      >
      {{
        desktop_image
        | image_url: width: 3840
        | image_tag:
          widths: widths,
          sizes: sizes,
          alt: alt_text,
          loading: 'lazy',
          class: 'full-width-image__img'
      }}
    </picture>
  {%- elsif primary_image != blank -%}
    {{
      primary_image
      | image_url: width: 3840
      | image_tag:
        widths: widths,
        sizes: sizes,
        alt: alt_text,
        loading: 'lazy',
        class: 'full-width-image__img'
    }}
  {%- else -%}
    <div class="full-width-image__placeholder">
      {{ 'lifestyle-1' | placeholder_svg_tag: 'full-width-image__placeholder-svg' }}
    </div>
  {%- endif -%}
{% endcapture %}

{% if block_settings.link != blank %}
  <a
    href="{{ block_settings.link }}"
    class="full-width-image spacing-style"
    style="{{ style }}"
    {% if block_settings.open_in_new_tab %}
      target="_blank" rel="noopener"
    {% endif %}
    {{ block.shopify_attributes }}
  >
    {{ media }}
  </a>
{% else %}
  <div
    class="full-width-image spacing-style"
    style="{{ style }}"
    {{ block.shopify_attributes }}
  >
    {{ media }}
  </div>
{% endif %}

{% stylesheet %}
  .full-width-image {
    display: block;
    width: 100%;
  }

  .full-width-image__img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: var(--fwi-radius, 0);
  }

  .full-width-image__placeholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: var(--fwi-radius, 0);
    overflow: hidden;
  }

  .full-width-image__placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Full width image",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image",
      "info": "Optional. Shown below 750px screen width instead of the image above. Leave empty to reuse the same image on every screen size."
    },
    {
      "type": "text",
      "id": "alt",
      "label": "Alt text",
      "info": "Describe the image for customers using screen readers."
    },
    {
      "type": "header",
      "content": "Link"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:settings.link"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "t:settings.open_new_tab",
      "default": false
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Full width image",
      "category": "t:categories.basic"
    }
  ]
}
{% endschema %}
