{%- doc -%}
  Renders a "testimonial peek carousel" section: a centered header (heading
  with a metallic accent word + subheading) followed by a horizontally
  scrollable row of fixed-width testimonial cards. The next card always
  peeks partially at the edge; desktop adds prev/next arrows, mobile relies
  on native touch swipe.

  Every testimonial is a nested "_testimonial-peek-card" block, so merchants
  can add, remove or reorder reviews freely. All text, images, icons,
  colors, sizes, spacing, radius, card width and autoplay are configurable
  through the section and block schemas.
{%- enddoc -%}

<script
  src="{{ 'testimonial-peek-carousel.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{%- liquid
  assign section_settings = section.settings
  assign card_count = section.blocks.size

  if section_settings.background_color != blank
    render 'contrast-override', background_color: section_settings.background_color, section_id: section.id
  endif
-%}

<div
  class="section-background{% if section_settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
></div>

<div
  class="testimonial-peek-carousel spacing-style{% if section_settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
  style="
    {% render 'spacing-style', settings: section_settings %}
    --tpc-max-width: {{ section_settings.container_max_width }}px;
    --tpc-container-padding: {{ section_settings.container_padding }}px;
    --tpc-container-padding-mobile: {{ section_settings.container_padding_mobile }}px;
    --tpc-heading-color: {{ section_settings.heading_color }};
    --tpc-heading-size-mobile: {{ section_settings.heading_size_mobile }}px;
    --tpc-heading-size-desktop: {{ section_settings.heading_size_desktop }}px;
    --tpc-accent-dark: {{ section_settings.heading_accent_dark }};
    --tpc-accent-light: {{ section_settings.heading_accent_light }};
    --tpc-subheading-color: {{ section_settings.subheading_color }};
    --tpc-subheading-size: {{ section_settings.subheading_size }}px;
    --tpc-header-gap: {{ section_settings.header_gap }}px;
    --tpc-header-bottom-gap-mobile: {{ section_settings.header_bottom_gap_mobile }}px;
    --tpc-header-bottom-gap-desktop: {{ section_settings.header_bottom_gap_desktop }}px;
    --tpc-card-width-mobile: {{ section_settings.card_width_mobile }}%;
    --tpc-card-width-desktop: {{ section_settings.card_width_desktop }}px;
    --tpc-items-gap: {{ section_settings.items_gap }}px;
    --tpc-card-bg: {{ section_settings.card_background_color }};
    --tpc-card-border-color: {{ section_settings.card_border_color }};
    --tpc-card-border-width: {{ section_settings.card_border_width }}px;
    --tpc-card-radius: {{ section_settings.card_radius }}px;
    --tpc-card-padding: {{ section_settings.card_padding }}px;
    --tpc-card-content-gap: {{ section_settings.card_content_gap }}px;
    --tpc-card-min-height: {{ section_settings.card_min_height }}px;
    --tpc-star-color: {{ section_settings.star_color }};
    --tpc-star-size: {{ section_settings.star_size }}px;
    --tpc-star-gap: {{ section_settings.star_gap }}px;
    --tpc-quote-color: {{ section_settings.quote_color }};
    --tpc-quote-size: {{ section_settings.quote_font_size }}px;
    --tpc-avatar-size: {{ section_settings.avatar_size }}px;
    --tpc-avatar-bg: {{ section_settings.avatar_background_color }};
    --tpc-avatar-color: {{ section_settings.avatar_text_color }};
    --tpc-name-color: {{ section_settings.name_color }};
    --tpc-name-size: {{ section_settings.name_font_size }}px;
    --tpc-verified-color: {{ section_settings.verified_color }};
    --tpc-verified-check-color: {{ section_settings.verified_check_color }};
    --tpc-verified-size: {{ section_settings.verified_font_size }}px;
    --tpc-arrow-size: {{ section_settings.arrow_size }}px;
    --tpc-arrow-bg: {{ section_settings.arrow_background_color }};
    --tpc-arrow-border-color: {{ section_settings.arrow_border_color }};
    --tpc-arrow-border-width: {{ section_settings.arrow_border_width }}px;
    --tpc-arrow-radius: {{ section_settings.arrow_radius }}px;
    --tpc-arrow-icon-color: {{ section_settings.arrow_icon_color }};
    --tpc-arrow-gap: {{ section_settings.arrow_gap }}px;
    {% if section_settings.background_color != blank %}
      --tpc-bg: {{ section_settings.background_color }};
    {% endif %}
  "
  data-testid="testimonial-peek-carousel"
>
  <div class="testimonial-peek-carousel__container">
    <header class="testimonial-peek-carousel__header">
      {%- if section_settings.heading != blank -%}
        <h2 class="testimonial-peek-carousel__heading">{{ section_settings.heading }}</h2>
      {%- endif -%}

      {%- if section_settings.subheading != blank -%}
        <p class="testimonial-peek-carousel__subheading">{{ section_settings.subheading }}</p>
      {%- endif -%}
    </header>

    {%- if card_count > 0 -%}
      <testimonial-peek-carousel-component
        class="testimonial-peek-carousel__component"
        data-autoplay="{{ section_settings.autoplay }}"
        data-autoplay-speed="{{ section_settings.autoplay_speed }}"
      >
        <div
          class="testimonial-peek-carousel__track"
          ref="track"
        >
          {% content_for 'blocks' %}
        </div>

        {%- if section_settings.show_arrows and card_count > 1 -%}
          <div class="testimonial-peek-carousel__controls">
            <button
              type="button"
              class="testimonial-peek-carousel__arrow testimonial-peek-carousel__arrow--prev"
              ref="prevButton"
              on:click="/prev"
              aria-label="{{ 'accessibility.slideshow_previous' | t }}"
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                focusable="false"
              >
                <polyline points="15 18 9 12 15 6"></polyline>
              </svg>
            </button>
            <button
              type="button"
              class="testimonial-peek-carousel__arrow testimonial-peek-carousel__arrow--next"
              ref="nextButton"
              on:click="/next"
              aria-label="{{ 'accessibility.slideshow_next' | t }}"
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                focusable="false"
              >
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </button>
          </div>
        {%- endif -%}
      </testimonial-peek-carousel-component>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .testimonial-peek-carousel {
    width: 100%;
    overflow: hidden;
    background-color: var(--tpc-bg, transparent);
  }

  .testimonial-peek-carousel__container {
    max-width: var(--tpc-max-width, 1200px);
    margin: 0 auto;
    padding-inline: var(--tpc-container-padding-mobile, 15px);
  }

  .testimonial-peek-carousel__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--tpc-header-gap, 20px);
    text-align: center;
    margin-bottom: var(--tpc-header-bottom-gap-mobile, 30px);
  }

  .testimonial-peek-carousel__heading {
    margin: 0;
    max-width: 46ch;
    color: var(--tpc-heading-color, currentColor);
    font-size: var(--tpc-heading-size-mobile, 34px);
    font-weight: 800;
    line-height: 1.2;
  }

  .testimonial-peek-carousel__heading strong {
    font-weight: 800;
    background: linear-gradient(180deg, var(--tpc-accent-dark, #a3a3a3), var(--tpc-accent-light, #ffffff) 50%, var(--tpc-accent-dark, #a3a3a3));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }

  .testimonial-peek-carousel__subheading {
    margin: 0;
    max-width: 60ch;
    color: var(--tpc-subheading-color, currentColor);
    font-size: var(--tpc-subheading-size, 14px);
    line-height: 1.4;
  }

  .testimonial-peek-carousel__component {
    display: block;
    width: 100%;
  }

  .testimonial-peek-carousel__track {
    display: flex;
    gap: var(--tpc-items-gap, 20px);
    overflow-x: auto;
    overscroll-behavior-x: contain;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 4px;
  }

  .testimonial-peek-carousel__track::-webkit-scrollbar {
    display: none;
  }

  .testimonial-peek-carousel__controls {
    display: none;
    justify-content: center;
    gap: var(--tpc-arrow-gap, 12px);
    margin-top: 20px;
  }

  .testimonial-peek-carousel__arrow {
    width: var(--tpc-arrow-size, 40px);
    height: var(--tpc-arrow-size, 40px);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    background: var(--tpc-arrow-bg, transparent);
    color: var(--tpc-arrow-icon-color, currentColor);
    border: var(--tpc-arrow-border-width, 1px) solid var(--tpc-arrow-border-color, currentColor);
    border-radius: var(--tpc-arrow-radius, 25px);
    cursor: pointer;
    transition:
      opacity 0.3s ease,
      transform 0.2s ease;
  }

  .testimonial-peek-carousel__arrow:hover:not(:disabled) {
    transform: translateY(-2px);
  }

  .testimonial-peek-carousel__arrow:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  .testimonial-peek-carousel__arrow svg {
    width: 60%;
    height: 60%;
    display: block;
  }

  @media screen and (min-width: 750px) {
    .testimonial-peek-carousel__container {
      padding-inline: var(--tpc-container-padding, 20px);
    }

    .testimonial-peek-carousel__header {
      margin-bottom: var(--tpc-header-bottom-gap-desktop, 40px);
    }

    .testimonial-peek-carousel__heading {
      font-size: var(--tpc-heading-size-desktop, 52px);
    }

    .testimonial-peek-carousel__controls {
      display: flex;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonial-peek-carousel__track {
      scroll-behavior: auto;
    }
  }
{% endstylesheet %}

