    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom (mobile)",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Top (desktop)",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Bottom (desktop)",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "default": 50
