{%- doc -%}
  Ingredient steps: a two-tone heading (plain text + a gradient-highlighted
  word) and subheading, followed by an arrow-controlled carousel of
  ingredient cards (image + title + description). On desktop a fixed number
  of cards page at a time; on mobile the track becomes a native
  touch-swipeable horizontal scroller with one full-width card per view.

  Every ingredient is its own nested "_ingredient-step-card" block, so
  merchants can add, remove or reorder ingredients freely. Optional numbered
  badges can be enabled to label each step.
{%- enddoc -%}

<script
  src="{{ 'ingredient-steps.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{%- liquid
  assign section_settings = section.settings
  assign card_count = section.blocks.size
-%}

<div
  class="ingredient-steps spacing-style"
  data-mobile-layout="{{ section_settings.mobile_layout }}"
  style="
    {% render 'spacing-style', settings: section_settings %}
    --iks-bg-top: {{ section_settings.background_gradient_top }};
    --iks-bg-bottom: {{ section_settings.background_gradient_bottom }};
    --iks-max-width: {{ section_settings.container_max_width }}px;
    --iks-padding-x: {{ section_settings.container_padding }}px;
    --iks-padding-x-mobile: {{ section_settings.container_padding_mobile }}px;
    --iks-heading-size: {{ section_settings.heading_size_desktop }}px;
    --iks-heading-size-mobile: {{ section_settings.heading_size_mobile }}px;
    --iks-heading-color: {{ section_settings.heading_color }};
    --iks-highlight-start: {{ section_settings.highlight_color_start }};
    --iks-highlight-mid: {{ section_settings.highlight_color_mid }};
    --iks-highlight-end: {{ section_settings.highlight_color_end }};
    --iks-subheading-size: {{ section_settings.subheading_size_desktop }}px;
    --iks-subheading-size-mobile: {{ section_settings.subheading_size_mobile }}px;
    --iks-subheading-color: {{ section_settings.subheading_color }};
    --iks-step-title-size: {{ section_settings.step_title_size_desktop }}px;
    --iks-step-title-size-mobile: {{ section_settings.step_title_size_mobile }}px;
    --iks-step-title-color: {{ section_settings.step_title_color }};
    --iks-step-description-size: {{ section_settings.step_description_size_desktop }}px;
    --iks-step-description-size-mobile: {{ section_settings.step_description_size_mobile }}px;
    --iks-step-description-color: {{ section_settings.step_description_color }};
    --iks-columns: {{ section_settings.columns_desktop }};
    --iks-gap: {{ section_settings.items_gap }}px;
    --iks-mobile-slide-padding: {{ section_settings.mobile_slide_padding }}px;
    --iks-transition-speed: {{ section_settings.transition_speed }}ms;
    --iks-nav-btn-size: {{ section_settings.nav_button_size }}px;
    --iks-nav-btn-bg: {{ section_settings.nav_button_bg_color }};
    --iks-nav-btn-border-color: {{ section_settings.nav_button_border_color }};
    --iks-nav-btn-icon-color: {{ section_settings.nav_button_icon_color }};
    --iks-number-bg: {{ section_settings.number_bg_color }};
    --iks-number-border-color: {{ section_settings.number_border_color }};
    --iks-number-text-color: {{ section_settings.number_text_color }};
    --iks-number-size: {{ section_settings.number_size_desktop }}px;
    --iks-number-size-mobile: {{ section_settings.number_size_mobile }}px;
    --iks-number-circle-size: {{ section_settings.number_circle_size }}px;
    --iks-card-border-radius: {{ section_settings.card_border_radius }}px;
    --iks-card-border-width: {{ section_settings.card_border_width }}px;
    --iks-card-border-color: {{ section_settings.card_border_color }};
    --iks-image-aspect: {{ section_settings.image_aspect_ratio }};
    --iks-image-fit: {{ section_settings.image_fit }};
    --iks-default-image-bg: {{ section_settings.default_image_background_color }};
    --iks-default-content-bg: {{ section_settings.default_content_background_color }};
    --iks-content-padding-v: {{ section_settings.content_padding_vertical }}px;
    --iks-content-padding-h: {{ section_settings.content_padding_horizontal }}px;
  "
  data-testid="ingredient-steps"
>
  <div class="ingredient-steps__container">
    {%- if section_settings.heading_line_1 != blank or section_settings.heading_highlight != blank -%}
      <h2 class="ingredient-steps__heading">
        {%- if section_settings.heading_line_1 != blank -%}
          {{- section_settings.heading_line_1 -}}
        {%- endif -%}
        {%- if section_settings.heading_highlight != blank -%}
          {{ ' ' }}<span class="ingredient-steps__heading-highlight">{{- section_settings.heading_highlight -}}</span>
        {%- endif -%}
      </h2>
    {%- endif -%}

    {%- if section_settings.subheading != blank -%}
      <div class="ingredient-steps__subheading rte">{{ section_settings.subheading }}</div>
    {%- endif -%}

    {%- if card_count > 0 -%}
      <ingredient-steps-component
        class="ingredient-steps__component"
        data-autoplay="{{ section_settings.autoplay }}"
        data-autoplay-speed="{{ section_settings.autoplay_speed }}"
      >
        <div
          class="ingredient-steps__wrapper"
          ref="wrapper"
        >
          <div
            class="ingredient-steps__track"
            ref="track"
          >
            {% content_for 'blocks' %}
          </div>
        </div>

        {%- if section_settings.show_arrows and card_count > 1 -%}
          <div class="ingredient-steps__nav">
            <button
              type="button"
              class="ingredient-steps__nav-btn ingredient-steps__nav-btn--prev"
              ref="prevButton"
              on:click="/prev"
              aria-label="{{ 'accessibility.slideshow_previous' | t }}"
            >
              <svg
                viewBox="0 0 20 20"
                fill="none"
                aria-hidden="true"
                focusable="false"
              >
                <path
                  d="M8 5L13 10L8 15"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </button>
            <button
              type="button"
              class="ingredient-steps__nav-btn ingredient-steps__nav-btn--next"
              ref="nextButton"
              on:click="/next"
              aria-label="{{ 'accessibility.slideshow_next' | t }}"
            >
              <svg
                viewBox="0 0 20 20"
                fill="none"
                aria-hidden="true"
                focusable="false"
              >
                <path
                  d="M8 5L13 10L8 15"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </button>
          </div>
        {%- endif -%}
      </ingredient-steps-component>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .ingredient-steps {
    width: 100%;
    overflow: hidden;
    background: linear-gradient(180deg, var(--iks-bg-top, #1c3353), var(--iks-bg-bottom, #141720));
    font-family: var(--font-body--family, inherit);
  }

  .ingredient-steps__container {
    max-width: var(--iks-max-width, 1200px);
    margin: 0 auto;
    padding-inline: var(--iks-padding-x-mobile, 16px);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .ingredient-steps__heading {
    font-family: var(--font-heading--family, inherit);
    font-weight: 700;
    font-size: var(--iks-heading-size-mobile, 36px);
    line-height: 1.2;
    color: var(--iks-heading-color, #ffffff);
    text-align: center;
    margin: 0 0 10px;
  }

  .ingredient-steps__heading-highlight {
    background: linear-gradient(
      180deg,
      var(--iks-highlight-start, #b8b8b8),
      var(--iks-highlight-mid, #ffffff),
      var(--iks-highlight-end, #b8b8b8)
    );
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }

  .ingredient-steps__subheading,
  .ingredient-steps__subheading p {
    font-size: var(--iks-subheading-size-mobile, 14px);
    color: var(--iks-subheading-color, #ffffff);
    text-align: center;
    max-width: 800px;
    line-height: 1.4;
    margin: 0 0 20px;
  }

  .ingredient-steps__component {
    display: block;
    width: 100%;
  }

  .ingredient-steps__wrapper {
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  .ingredient-steps__track {
    display: flex;
    gap: 0px;
    transition: transform var(--iks-transition-speed, 300ms) ease;
    will-change: transform;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .ingredient-steps__track::-webkit-scrollbar {
    display: none;
  }

  .ingredient-steps__nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-top: 20px;
  }

  .ingredient-steps__nav-btn {
    width: var(--iks-nav-btn-size, 40px);
    height: var(--iks-nav-btn-size, 40px);
    border-radius: 50%;
    border: 1px solid var(--iks-nav-btn-border-color, #0954bc);
    background: var(--iks-nav-btn-bg, #0e203e);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--iks-nav-btn-icon-color, #ffffff);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .ingredient-steps__nav-btn:hover:not(:disabled) {
    transform: translateY(-2px);
  }

  .ingredient-steps__nav-btn:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  .ingredient-steps__nav-btn svg {
    width: 14px;
    height: 14px;
    display: block;
    flex-shrink: 0;
  }

  .ingredient-steps__nav-btn--prev svg {
    transform: scaleX(-1);
  }

  @media screen and (min-width: 750px) {
    .ingredient-steps__container {
      padding-inline: var(--iks-padding-x, 20px);
    }

    .ingredient-steps__heading {
      font-size: var(--iks-heading-size, 52px);
      margin-bottom: 16px;
    }

    .ingredient-steps__subheading,
    .ingredient-steps__subheading p {
      font-size: var(--iks-subheading-size, 18px);
      margin-bottom: 32px;
    }

    .ingredient-steps__track {
      gap: var(--iks-gap, 5px);
      overflow-x: visible;
      scroll-snap-type: none;
    }
  }
{% endstylesheet %}

