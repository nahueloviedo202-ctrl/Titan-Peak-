    },
    {
      "type": "range",
      "id": "icon_size_desktop",
      "label": "Checkmark/X size (desktop)",
      "min": 14,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "icon_size_mobile",
      "label": "Checkmark/X size (mobile)",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "default_check_yes_color",
      "label": "Checkmark color (non-highlighted)",
      "default": "#ffffff"
    },
